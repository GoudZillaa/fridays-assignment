savePreferencesBtn:"Save preferences",closeIconLabel:"Close",sections:[{title:"Cookie usage",description:"We use cookies to ensure the basic functionalities of the website, enhance your online experience, and analyze site traffic. You can choose for each category to opt-in or opt-out whenever you want."},{title:"Strictly necessary cookies",description:"These cookies are essential for the proper functioning of our website. Without these cookies, the website would not work properly.",linkedCategory:ir.NECESSARY},{title:"Analytics cookies",description:"These cookies collect information about how you use our website. All data is anonymized and cannot be used to identify you.",linkedCategory:ir.ANALYTICS},{title:"Marketing cookies",description:"These cookies are used to make advertising messages more relevant to you and your interests. They also help measure the effectiveness of marketing campaigns.",linkedCategory:ir.MARKETING},{title:"More information",description:`For any questions regarding our cookie policy and your choices, please visit our <a href="${Jr.PRIVACY_AND_POLICY}" target="_blank" rel="noopener noreferrer">Privacy Policy</a>.`}]}},es:{consentModal:{title:"Usamos cookies",description:"Utilizamos cookies y tecnologías similares para mejorar tu experiencia, analizar el tráfico del sitio y personalizar contenido. Puedes gestionar tus preferencias en cualquier momento.",acceptAllBtn:"Aceptar todo",acceptNecessaryBtn:"Rechazar todo",showPreferencesBtn:"Gestionar preferencias",closeIconLabel:"Cerrar",footer:`<a href="${Jr.PRIVACY_AND_POLICY}" target="_blank" rel="noopener noreferrer">Política de privacidad</a>`},preferencesModal:{title:"Preferencias de cookies",acceptAllBtn:"Aceptar todo",acceptNecessaryBtn:"Rechazar todo",savePreferencesBtn:"Guardar preferencias",closeIconLabel:"Cerrar",sections:[{title:"Uso de cookies",description:"Utilizamos cookies para garantizar las funcionalidades básicas del sitio web, mejorar tu experiencia en línea y analizar el tráfico del sitio. Puedes elegir para cada categoría activar o desactivar cuando quieras."},{title:"Cookies estrictamente necesarias",description:"Estas cookies son esenciales para el correcto funcionamiento de nuestro sitio web. Sin estas cookies, el sitio web no funcionaría correctamente.",linkedCategory:ir.NECESSARY},{title:"Cookies de análisis",description:"Estas cookies recopilan información sobre cómo usas nuestro sitio web. Todos los datos son anónimos y no pueden usarse para identificarte.",linkedCategory:ir.ANALYTICS},{title:"Cookies de marketing",description:"Estas cookies se utilizan para que los mensajes publicitarios sean más relevantes para ti y tus intereses. También ayudan a medir la efectividad de las campañas de marketing.",linkedCategory:ir.MARKETING},{title:"Más información",description:`Para cualquier pregunta sobre nuestra política de cookies y tus opciones, visita nuestra <a href="${Jr.PRIVACY_AND_POLICY}" target="_blank" rel="noopener noreferrer">Política de privacidad</a>.`}]}}}}},uJt=()=>{const e=zr(t=>t.language);return C.useEffect(()=>{(async()=>{if(await aJt(cJt),oJt().acceptType)return;const r=lJt();r&&r.length>0&&(FG(r),zG())})()},[]),C.useEffect(()=>{iJt(e)},[e]),null},dJt="utf-8",fJt={"Content-Type":"text/plain; charset=utf-8","Plural-Forms":"nplurals = 2; plural = (n != 1);",Language:"es","MIME-Version":"1.0","Content-Transfer-Encoding":"8bit"},mJt=JSON.parse('{"":{"":{"msgid":"","msgstr":["Content-Type: text/plain; charset=utf-8\\nPlural-Forms: nplurals = 2; plural = (n != 1);\\nLanguage: es\\nMIME-Version: 1.0\\nContent-Transfer-Encoding: 8bit\\n"]},"Maximum size: 4MB":{"msgid":"Maximum size: 4MB","msgstr":["Tamaño máximo: 4MB"]},"Password is required":{"msgid":"Password is required","msgstr":["Ingrese contraseña"]},"Passwords must match":{"msgid":"Passwords must match","msgstr":["Las contraseñas deben coincidir"]},"First name is required":{"msgid":"First name is required","msgstr":["Ingrese nombre"]},"Last name is required":{"msgid":"Last name is required","msgstr":["Ingrese apellido"]},"State is required":{"msgid":"State is required","msgstr":["Ingrese estado"]},"Gender is required":{"msgid":"Gender is required","msgstr":["Ingrese género"]},"Date of birth is required":{"msgid":"Date of birth is required","msgstr":["Ingrese fecha de nacimiento"]},"House and street number are required":{"msgid":"House and street number are required","msgstr":["Ingrese dirección"]},"Zip code is required":{"msgid":"Zip code is required","msgstr":["Ingrese código postal"]},"Timezone is required":{"msgid":"Timezone is required","msgstr":["Ingrese zona horaria"]},"Phone number is required":{"msgid":"Phone number is required","msgstr":["Ingrese número de teléfono"]},"File name is required":{"msgid":"File name is required","msgstr":["Ingrese nombre de archivo"]},"Oops! File too large (Max. ${ sizeInBytes }). Please try reducing the file size before uploading again.":{"msgid":"Oops! File too large (Max. ${ sizeInBytes }). Please try reducing the file size before uploading again.","msgstr":["¡Ups! Archivo demasiado grande (Máx. ${ sizeInBytes }). Por favor, intenta reducir el tamaño del archivo antes de volver a subirlo."]},"Drop your files here":{"msgid":"Drop your files here","msgstr":["Añade tus archivos aquí"]},"Drag \'n\' drop some files here, or click to select files":{"msgid":"Drag \'n\' drop some files here, or click to select files","msgstr":["Arrastra y añadí algunos archivos aquí, o haz clic para seleccionar archivos"]},"Image already uploaded, upload another file to change it":{"msgid":"Image already uploaded, upload another file to change it","msgstr":["Imagen ya subida, sube otro archivo para cambiarla"]},"No options available":{"msgid":"No options available","msgstr":["No hay opciones disponibles"]},"Go back":{"msgid":"Go back","msgstr":["Volver"]},"Loading...":{"msgid":"Loading...","msgstr":["Cargando..."]},"Reset password":{"msgid":"Reset password","msgstr":["Restablecer contraseña"]},"Your password has been reset successfully!":{"msgid":"Your password has been reset successfully!","msgstr":["¡Tu contraseña ha sido restablecida con éxito!"]},"Create a new safe password":{"msgid":"Create a new safe password","msgstr":["Crea una nueva contraseña segura"]},"Confirm password":{"msgid":"Confirm password","msgstr":["Confirmar contraseña"]},"Save changes":{"msgid":"Save changes","msgstr":["Guardar cambios"]},"Cancel":{"msgid":"Cancel","msgstr":["Cancelar"]},"Profile successfully updated!":{"msgid":"Profile successfully updated!","msgstr":["¡Perfil actualizado con éxito!"]},"Edit profile":{"msgid":"Edit profile","msgstr":["Editar perfil"]},"My profile":{"msgid":"My profile","msgstr":["Mi perfil"]},"General information":{"msgid":"General information","msgstr":["Información general"]},"E.g. John":{"msgid":"E.g. John","msgstr":["Ej. Juan"]},"E.g. Doe":{"msgid":"E.g. Doe","msgstr":["Ej. Pérez"]},"Date of birth *":{"msgid":"Date of birth *","msgstr":["Fecha de nacimiento *"]},"Contact":{"msgid":"Contact","msgstr":["Contacto"]},"Apartment number":{"msgid":"Apartment number","msgstr":["Número de apartamento"]},"E.g. 1A":{"msgid":"E.g. 1A","msgstr":["Ej. 1A"]},"E.g. New York":{"msgid":"E.g. New York","msgstr":["Ej. Nueva York"]},"E.g. Phoenix":{"msgid":"E.g. Phoenix","msgstr":["Ej. Phoenix"]},"E.g. PST":{"msgid":"E.g. PST","msgstr":["Ej. PST"]},"Insurance":{"msgid":"Insurance","msgstr":["Seguro"]},"Insurance card":{"msgid":"Insurance card","msgstr":["Tarjeta de seguro"]},"Drop your front card image here":{"msgid":"Drop your front card image here","msgstr":["Añade aquí la imagen de la parte frontal de tu tarjeta"]},"Front card uploaded":{"msgid":"Front card uploaded","msgstr":["Frente de la tarjeta subida"]},"Drop your back card image here":{"msgid":"Drop your back card image here","msgstr":["Añade aquí la imagen del dorso de tu tarjeta"]},"Back card uploaded":{"msgid":"Back card uploaded","msgstr":["Dorso de la tarjeta subida"]},"First name":{"msgid":"First name","msgstr":["Nombre"]},"Last name":{"msgid":"Last name","msgstr":["Apellido"]},"Sex assigned at birth":{"msgid":"Sex assigned at birth","msgstr":["Sexo asignado al nacer"]},"Date of birth":{"msgid":"Date of birth","msgstr":["Fecha de nacimiento"]},"Email address":{"msgid":"Email address","msgstr":["Correo electrónico"]},"Phone number":{"msgid":"Phone number","msgstr":["Número de teléfono"]},"House and street #":{"msgid":"House and street #","msgstr":["Dirección"]},"Zip code":{"msgid":"Zip code","msgstr":["Código postal"]},"City":{"msgid":"City","msgstr":["Ciudad"]},"State":{"msgid":"State","msgstr":["Estado"]},"Country":{"msgid":"Country","msgstr":["País"]},"Insurance card successfully updated!":{"msgid":"Insurance card successfully updated!","msgstr":["¡Tarjeta de seguro actualizada con éxito!"]},"Insurance card front":{"msgid":"Insurance card front","msgstr":["Frente de la tarjeta de seguro"]},"No photo uploaded yet.":{"msgid":"No photo uploaded yet.","msgstr":["No se ha subido ninguna foto aún."]},"This area is for the front side of your insurance card.":{"msgid":"This area is for the front side of your insurance card.","msgstr":["Esta área es para el lado frontal de tu tarjeta de seguro."]},"Drop your front card photo here":{"msgid":"Drop your front card photo here","msgstr":["Añade aquí la foto de la parte frontal de tu tarjeta"]},"Insurance card back":{"msgid":"Insurance card back","msgstr":["Dorso de la tarjeta de seguro"]},"This area is for the back side of your insurance card.":{"msgid":"This area is for the back side of your insurance card.","msgstr":["Esta área es para el dorso de su tarjeta de seguro."]},"Drop your back card photo here":{"msgid":"Drop your back card photo here","msgstr":["Añade aquí la foto del dorso de tu tarjeta"]},"Continue":{"msgid":"Continue","msgstr":["Continuar"]},"Back":{"msgid":"Back","msgstr":["Volver"]},"Next":{"msgid":"Next","msgstr":["Siguiente"]},"It appears that Fridays treatments may not be the best fit for you at the moment":{"msgid":"It appears that Fridays treatments may not be the best fit for you at the moment","msgstr":["Parece que los tratamientos de Fridays pueden no ser la mejor opción para ti en este momento"]},"Your journey to wellness is personal and unique. While Fridays may not align with your current needs, it\'s just the beginning of discovering what works best for you. Keep exploring, and you\'ll find the perfect fit.":{"msgid":"Your journey to wellness is personal and unique. While Fridays may not align with your current needs, it\'s just the beginning of discovering what works best for you. Keep exploring, and you\'ll find the perfect fit.","msgstr":["Tu viaje hacia el bienestar es personal y único. Aunque Fridays puede que no se alinee con tus necesidades actuales, es solo el comienzo de descubrir lo que mejor funciona para ti. Sigue explorando y encontrarás la opción perfecta."]},"We\'re excited to join you on this wellness journey. Let\'s make every day feel like a Friday! 🎉":{"msgid":"We\'re excited to join you on this wellness journey. Let\'s make every day feel like a Friday! 🎉","msgstr":["Estamos emocionados de acompañarte en este viaje hacia el bienestar. ¡Hagamos que cada día se sienta como un viernes! 🎉"]},"Start your journey!":{"msgid":"Start your journey!","msgstr":["¡Comienza tu viaje!"]},"(*) Mandatory field":{"msgid":"(*) Mandatory field","msgstr":["(*) Campo obligatorio"]},"E.g. 5":{"msgid":"E.g. 5","msgstr":["Ej. 5"]},"E.g. 3":{"msgid":"E.g. 3","msgstr":["Ej. 3"]},"Create your password":{"msgid":"Create your password","msgstr":["Crea tu contraseña"]},"Password *":{"msgid":"Password *","msgstr":["Contraseña *"]},"Password":{"msgid":"Password","msgstr":["Contraseña"]},"Confirm password *":{"msgid":"Confirm password *","msgstr":["Confirmar contraseña *"]},"Error updating payment method, try again later or use a different card.":{"msgid":"Error updating payment method, try again later or use a different card.","msgstr":["Error al actualizar el método de pago, intenta nuevamente más tarde o usa una tarjeta diferente."]},"Payment details":{"msgid":"Payment details","msgstr":["Detalles de pago"]},"Card number *":{"msgid":"Card number *","msgstr":["Número de tarjeta *"]},"Optional coupon code":{"msgid":"Optional coupon code","msgstr":["Cupón de descuento"]},"Apply":{"msgid":"Apply","msgstr":["Aplicar"]},"Pay":{"msgid":"Pay","msgstr":["Pagar"]},"Payment successfully processed!":{"msgid":"Payment successfully processed!","msgstr":["¡Pago procesado con éxito!"]},"Your payment has been processed correctly.":{"msgid":"Your payment has been processed correctly.","msgstr":["Tu pago ha sido procesado correctamente."]},"You can now create your password to continue":{"msgid":"You can now create your password to continue","msgstr":["Ahora puedes crear tu contraseña para continuar"]},"Create password":{"msgid":"Create password","msgstr":["Crear contraseña"]},"month":{"msgid":"month","msgstr":["mes"]},"Tell us about yourself":{"msgid":"Tell us about yourself","msgstr":["Cuéntanos sobre ti"]},"Begin your journey":{"msgid":"Begin your journey","msgstr":["Comienza tu viaje"]},"Fastest":{"msgid":"Fastest","msgstr":["Más rápido"]},"Unlock the door to your health journey with our platform. Schedule your inaugural video call with a medical professional, marking the beginning of your personalized treatment plan. Let\'s embark together on this path towards improved well-being and vitality.":{"msgid":"Unlock the door to your health journey with our platform. Schedule your inaugural video call with a medical professional, marking the beginning of your personalized treatment plan. Let\'s embark together on this path towards improved well-being and vitality.","msgstr":["Desbloquea la puerta a tu viaje de salud con nuestra plataforma. Programa tu llamada de video inaugural con un profesional médico, marcando el comienzo de tu plan de tratamiento personalizado. Embarquémonos juntos en este camino hacia un mejor bienestar y vitalidad."]},"Due to your current medical situation, at this time we cannot make a refill request, you must see a provider first.":{"msgid":"Due to your current medical situation, at this time we cannot make a refill request, you must see a provider first.","msgstr":["Debido a tu situación médica actual, en este momento no podemos hacer una solicitud de recarga, debes ver a un profesional de la salud primero."]},"Choose the perfect time and date":{"msgid":"Choose the perfect time and date","msgstr":["Elige la hora y fecha perfectas"]},"Intake form questions":{"msgid":"Intake form questions","msgstr":["Preguntas del formulario de admisión"]},"My Meds":{"msgid":"My Meds","msgstr":["Mis Medicamentos"]},"You will be able to order medication after your third injection date\\non ${ thirdInjectionDate }":{"msgid":"You will be able to order medication after your third injection date\\non ${ thirdInjectionDate }","msgstr":["Podrás ordenar medicamentos después de la fecha de tu tercera inyección\\nel ${ thirdInjectionDate }"]},"Current medication requests":{"msgid":"Current medication requests","msgstr":["Solicitudes de medicamentos actuales"]},"Having any trouble with your medication delivery?":{"msgid":"Having any trouble with your medication delivery?","msgstr":["¿Tienes problemas con la entrega de tus medicamentos?"]},"Get in touch with our support team!":{"msgid":"Get in touch with our support team!","msgstr":["¡Ponte en contacto con nuestro equipo de soporte!"]},"Get in touch":{"msgid":"Get in touch","msgstr":["Ponte en contacto"]},"Medication requests":{"msgid":"Medication requests","msgstr":["Solicitudes de medicamentos"]},"Drug name":{"msgid":"Drug name","msgstr":["Nombre del medicamento"]},"Dose":{"msgid":"Dose","msgstr":["Dosis"]},"Date":{"msgid":"Date","msgstr":["Fecha"]},"Status":{"msgid":"Status","msgstr":["Estado"]},"Tracking #":{"msgid":"Tracking #","msgstr":["Número de seguimiento"]},"Tracking":{"msgid":"Tracking","msgstr":["Seguimiento"]},"Drug":{"msgid":"Drug","msgstr":["Medicamento"]},"Subscription Update Needed":{"msgid":"Subscription Update Needed","msgstr":["Se necesita actualización de suscripción"]},"Change subscription":{"msgid":"Change subscription","msgstr":["Cambiar suscripción"]},"It\'s nice to see you again!":{"msgid":"It\'s nice to see you again!","msgstr":["¡Es un placer verte de nuevo!"]},"Email":{"msgid":"Email","msgstr":["Correo electrónico"]},"email@example.com":{"msgid":"email@example.com","msgstr":["correo@ejemplo.com"]},"Forgot your password?":{"msgid":"Forgot your password?","msgstr":["¿Olvidaste tu contraseña?"]},"Create my account":{"msgid":"Create my account","msgstr":["Crear mi cuenta"]},"My agenda":{"msgid":"My agenda","msgstr":["Mi agenda"]},"Progress tracker":{"msgid":"Progress tracker","msgstr":["Monitor de progreso"]},"Medication refill requests":{"msgid":"Medication refill requests","msgstr":["Solicitud de medicamento"]},"View all requests":{"msgid":"View all requests","msgstr":["Ver todas las solicitudes"]},"Payment failed":{"msgid":"Payment failed","msgstr":["El pago falló"]},"There was an issue processing your payment. Please check your details and try again, or use a different payment method.":{"msgid":"There was an issue processing your payment. Please check your details and try again, or use a different payment method.","msgstr":["Hubo un problema al procesar tu pago. Por favor verifica tus datos y vuelve a intentarlo, o usa un método de pago diferente."]},"Forgot password?":{"msgid":"Forgot password?","msgstr":["¿Olvidaste tu contraseña?"]},"Please enter your registered email address.":{"msgid":"Please enter your registered email address.","msgstr":["Por favor ingresa tu dirección de correo electrónico registrada."]},"We will send you a link to reset your password.":{"msgid":"We will send you a link to reset your password.","msgstr":["Te enviaremos un enlace para restablecer tu contraseña."]},"Back to log in":{"msgid":"Back to log in","msgstr":["Volver a iniciar sesión"]},"Send email":{"msgid":"Send email","msgstr":["Enviar correo"]},"No documents found in this folder.":{"msgid":"No documents found in this folder.","msgstr":["No se encontraron documentos en esta carpeta."]},"You can upload new documents using the button above.":{"msgid":"You can upload new documents using the button above.","msgstr":["Puedes subir nuevos documentos usando el botón de arriba."]},"Add previous prescriptions":{"msgid":"Add previous prescriptions","msgstr":["Agregar prescripciones anteriores"]},"Document center":{"msgid":"Document center","msgstr":["Centro de Documentos"]},"Previous prescriptions":{"msgid":"Previous prescriptions","msgstr":["Prescripciones anteriores"]},"Previous Prescriptions":{"msgid":"Previous Prescriptions","msgstr":["Prescripciones Anteriores"]},"Browse through your Previous Prescriptions to find specific documents. Tap on a document to view it in detail.":{"msgid":"Browse through your Previous Prescriptions to find specific documents. Tap on a document to view it in detail.","msgstr":["Navega a través de tus Prescripciones Anteriores para encontrar documentos específicos. Toca un documento para verlo en detalle."]},"Doctor\'s Notes":{"msgid":"Doctor\'s Notes","msgstr":["Notas del Doctor"]},"Access your doctor\'s notes and recommendations.":{"msgid":"Access your doctor\'s notes and recommendations.","msgstr":["Accede a las notas y recomendaciones de tu doctor."]},"View details":{"msgid":"View details","msgstr":["Ver detalles"]},"Fridays\' Resources":{"msgid":"Fridays\' Resources","msgstr":["Recursos de Fridays"]},"Stay informed with the latest news and updates from Fridays.":{"msgid":"Stay informed with the latest news and updates from Fridays.","msgstr":["Mantente informado con las últimas noticias y actualizaciones de Fridays."]},"Access valuable resources, articles, and company announcements here.":{"msgid":"Access valuable resources, articles, and company announcements here.","msgstr":["Accede a recursos valiosos, artículos y anuncios de la empresa aquí."]},"Access resources":{"msgid":"Access resources","msgstr":["Acceder a recursos"]},"Labs":{"msgid":"Labs","msgstr":["Laboratorios"]},"View and manage your lab results and lab orders here.":{"msgid":"View and manage your lab results and lab orders here.","msgstr":["Ve y gestiona tus resultados de laboratorio y órdenes de laboratorio aquí."]},"Upload lab test":{"msgid":"Upload lab test","msgstr":["Subir prueba de laboratorio"]},"Other Documents":{"msgid":"Other Documents","msgstr":["Otros Documentos"]},"Upload medical records":{"msgid":"Upload medical records","msgstr":["Subir registros médicos"]},"Upload your past prescriptions for your provider to access.":{"msgid":"Upload your past prescriptions for your provider to access.","msgstr":["Sube tus prescripciones anteriores para que tu profesional de la salud pueda acceder a ellas."]},"Upload prescription":{"msgid":"Upload prescription","msgstr":["Subir prescripción"]},"Add medical records":{"msgid":"Add medical records","msgstr":["Agregar registros médicos"]},"Medical records":{"msgid":"Medical records","msgstr":["Registros médicos"]},"Your lab orders":{"msgid":"Your lab orders","msgstr":["Tus órdenes de laboratorio"]},"Lab results":{"msgid":"Lab results","msgstr":["Resultados de laboratorio"]},"Add lab result":{"msgid":"Add lab result","msgstr":["Agregar resultado de laboratorio"]},"Browse through your Lab Results to find specific documents. Tap on a document to view it in detail.":{"msgid":"Browse through your Lab Results to find specific documents. Tap on a document to view it in detail.","msgstr":["Navega a través de tus Resultados de Laboratorio para encontrar documentos específicos. Toca un documento para verlo en detalle."]},"Doctor\'s notes":{"msgid":"Doctor\'s notes","msgstr":["Notas del doctor"]},"Your doctor\'s notes and recommendations":{"msgid":"Your doctor\'s notes and recommendations","msgstr":["Las notas y recomendaciones de tu doctor"]},"New Consultation":{"msgid":"New Consultation","msgstr":["Nueva Consulta"]},"Consultations":{"msgid":"Consultations","msgstr":["Consultas"]},"Schedule new consultation":{"msgid":"Schedule new consultation","msgstr":["Programar nueva consulta"]},"Consultation successfully created!":{"msgid":"Consultation successfully created!","msgstr":["¡Consulta creada con éxito!"]},"Review consultations":{"msgid":"Review consultations","msgstr":["Revisar consultas"]},"Consultation Purpose":{"msgid":"Consultation Purpose","msgstr":["Propósito de la Consulta"]},"Select the option that best applies to you":{"msgid":"Select the option that best applies to you","msgstr":["Selecciona la opción que mejor se aplique a ti"]},"You will be able to review your medication request by visiting the “Your Meds” section":{"msgid":"You will be able to review your medication request by visiting the “Your Meds” section","msgstr":["Podrás revisar tu solicitud de medicamento visitando la sección “Tus Medicamentos”"]},"Order medication":{"msgid":"Order medication","msgstr":["Pedir medicamento"]},"Low on your meds? you can have your prescription within 2-3 days":{"msgid":"Low on your meds? you can have your prescription within 2-3 days","msgstr":["¿Te quedan pocos medicamentos? Puedes tener tu prescripción en 2-3 días"]},"No need for a video consultation! Just fill out the form, and we\'ll take care of everything. We\'re here to ensure the smoothest experience.":{"msgid":"No need for a video consultation! Just fill out the form, and we\'ll take care of everything. We\'re here to ensure the smoothest experience.","msgstr":["¡No necesitas una video-consulta! Solo completa el formulario y nos encargaremos de todo. Estamos aquí para asegurar la experiencia más fluida."]},"More info on medication refills":{"msgid":"More info on medication refills","msgstr":["Más información sobre recargas de medicamentos"]},"Video consultation":{"msgid":"Video consultation","msgstr":["Video-consulta"]},"Looking for some one-on-one time with a provider?":{"msgid":"Looking for some one-on-one time with a provider?","msgstr":["¿Buscas un tiempo uno a uno con un profesional de la salud?"]},"By opting for a video consultation, you can schedule an appointment to see a provider. Don\'t worry about the details; we\'ll be here to help you find the perfect time slot for your visit.":{"msgid":"By opting for a video consultation, you can schedule an appointment to see a provider. Don\'t worry about the details; we\'ll be here to help you find the perfect time slot for your visit.","msgstr":["Al optar por una video-consulta, puedes programar una cita para ver a un profesional de la salud. No te preocupes por los detalles; estaremos aquí para ayudarte a encontrar el horario perfecto para tu visita."]},"More info on video consultations":{"msgid":"More info on video consultations","msgstr":["Más información sobre video-consultas"]},"New consultation":{"msgid":"New consultation","msgstr":["Nueva consulta"]},"Want to review your refill medication requests?":{"msgid":"Want to review your refill medication requests?","msgstr":["¿Quieres revisar tus solicitudes de medicamentos?"]},"Go to My Meds":{"msgid":"Go to My Meds","msgstr":["Ir a Mis Medicamentos"]},"Provider":{"msgid":"Provider","msgstr":["Profesional"]},"Time":{"msgid":"Time","msgstr":["Hora"]},"Note":{"msgid":"Note","msgstr":["Nota"]},"You haven\'t had any consultation yet":{"msgid":"You haven\'t had any consultation yet","msgstr":["No has tenido ninguna consulta aún"]},"Notes":{"msgid":"Notes","msgstr":["Notas"]},"Medication refill request":{"msgid":"Medication refill request","msgstr":["Solicitud de medicamentos"]},"Follow up form":{"msgid":"Follow up form","msgstr":["Formulario de seguimiento"]},"These questions are required before further medication can be prescribed. Keep in mind that if you select any of the symptoms listed on this screen, you won\'t be able to continue with the Fridays program.":{"msgid":"These questions are required before further medication can be prescribed. Keep in mind that if you select any of the symptoms listed on this screen, you won\'t be able to continue with the Fridays program.","msgstr":["Estas preguntas son requeridas antes de que se pueda prescribir más medicamento. Ten en cuenta que si seleccionas alguno de los síntomas listados en esta pantalla, no podrás continuar con el programa de Fridays."]},"This question is required before further medication can be prescribed.":{"msgid":"This question is required before further medication can be prescribed.","msgstr":["Esta pregunta es requerida antes de que se pueda prescribir más medicamento."]},"Please take a moment to provide your responses to these follow-up questions. Your input is essential in guiding us to offer optimal care tailored to your progress.":{"msgid":"Please take a moment to provide your responses to these follow-up questions. Your input is essential in guiding us to offer optimal care tailored to your progress.","msgstr":["Por favor, tómate un momento para proporcionar tus respuestas a estas preguntas de seguimiento. Tu opinión es esencial para guiarnos a ofrecer la mejor atención adaptada a tu progreso."]},"Please spare a moment to fill out the medication refill request form. Your input is vital in facilitating a smooth and efficient refill process customized to your requirements.":{"msgid":"Please spare a moment to fill out the medication refill request form. Your input is vital in facilitating a smooth and efficient refill process customized to your requirements.","msgstr":["Por favor, tómate un momento para completar el formulario de solicitud de medicamentos. Tu opinión es vital para facilitar un proceso de recarga suave y eficiente adaptado a tus requisitos."]},"Would you like to proceed with your consultation anyway, or cancel and return later?":{"msgid":"Would you like to proceed with your consultation anyway, or cancel and return later?","msgstr":["¿Te gustaría continuar con tu consulta de todos modos, o cancelar y volver más tarde?"]},"Cancel request":{"msgid":"Cancel request","msgstr":["Cancelar solicitud"]},"Submit":{"msgid":"Submit","msgstr":["Enviar"]},"Note to female patients of reproductive potential":{"msgid":"Note to female patients of reproductive potential","msgstr":["Nota para pacientes femeninas con potencial reproductivo"]},"Please note that we strongly recommend that you use an effective method of contraception during treatment with a GLP-1 medication and for at least 2 months thereafter. For those taking Zepbound or Mounjaro (tirzepatide), we recommend switching to a non-oral contraceptive method or adding a barrier method of contraception for four weeks after initiation and for four weeks after each dose escalation.":{"msgid":"Please note that we strongly recommend that you use an effective method of contraception during treatment with a GLP-1 medication and for at least 2 months thereafter. For those taking Zepbound or Mounjaro (tirzepatide), we recommend switching to a non-oral contraceptive method or adding a barrier method of contraception for four weeks after initiation and for four weeks after each dose escalation.","msgstr":["Por favor, ten en cuenta que recomendamos encarecidamente que utilices un método anticonceptivo efectivo durante el tratamiento con un medicamento GLP-1 y durante al menos 2 meses después. Para aquellos que toman Zepbound o Mounjaro (tirzepatide), recomendamos cambiar a un método anticonceptivo no oral o agregar un método de barrera de anticoncepción durante cuatro semanas después de la iniciación y durante cuatro semanas después de cada aumento de dosis."]},"Have you experienced any of the following since starting medication?":{"msgid":"Have you experienced any of the following since starting medication?","msgstr":["¿Has experimentado alguno de los siguientes desde que comenzaste el tratamiento?"]},"Chest pain, heart palpitations, or racing heart":{"msgid":"Chest pain, heart palpitations, or racing heart","msgstr":["Dolor en el pecho, palpitaciones o corazón acelerado"]},"Seizures":{"msgid":"Seizures","msgstr":["Convulsiones"]},"Concerning and/or serious mood changes":{"msgid":"Concerning and/or serious mood changes","msgstr":["Cambios de humor preocupantes y/o serios"]},"Is there any specific medical circumstance affecting your health currently or in the past?":{"msgid":"Is there any specific medical circumstance affecting your health currently or in the past?","msgstr":["¿Hay alguna circunstancia médica específica que afecte tu salud actualmente o en el pasado?"]},"Current or possibly pregnant, or actively trying to become pregnant.":{"msgid":"Current or possibly pregnant, or actively trying to become pregnant.","msgstr":["Actualmente o posiblemente embarazada, o intentando activamente quedar embarazada."]},"Breastfeeding or bottle feeding with breastmilk?":{"msgid":"Breastfeeding or bottle feeding with breastmilk?","msgstr":["¿Amamantando o alimentando con biberón con leche materna?"]},"End-stage kidney disease?":{"msgid":"End-stage kidney disease?","msgstr":["Enfermedad renal en etapa terminal?"]},"(on or about to be in dialysis)":{"msgid":"(on or about to be in dialysis)","msgstr":["(en diálisis o a punto de estar en diálisis)"]},"End-stage liver disease?":{"msgid":"End-stage liver disease?","msgstr":["Enfermedad hepática en etapa terminal?"]},"(cirrhosis)":{"msgid":"(cirrhosis)","msgstr":["(cirrosis)"]},"Current or prior eating disorder?":{"msgid":"Current or prior eating disorder?","msgstr":["¿Trastorno alimentario actual o anterior?"]},"(anorexia or bulimia)":{"msgid":"(anorexia or bulimia)","msgstr":["(anorexia o bulimia)"]},"Current suicidal thoughts and/or prior suicidal attempt?":{"msgid":"Current suicidal thoughts and/or prior suicidal attempt?","msgstr":["¿Pensamientos suicidas actuales y/o intento suicida previo?"]},"Cancer?":{"msgid":"Cancer?","msgstr":["¿Cáncer?"]},"(active diagnosis or treatment)":{"msgid":"(active diagnosis or treatment)","msgstr":["(diagnóstico o tratamiento activo)"]},"History of organ transplant or anti rejection medication?":{"msgid":"History of organ transplant or anti rejection medication?","msgstr":["¿Historia de trasplante de órganos o medicamentos anti rechazo?"]},"Severe gastrointestinal condition?":{"msgid":"Severe gastrointestinal condition?","msgstr":["¿Condición gastrointestinal severa?"]},"(gastroparesis, inflammatory bowel disease)":{"msgid":"(gastroparesis, inflammatory bowel disease)","msgstr":["(gastroparesia, enfermedad inflamatoria intestinal)"]},"Past sessions":{"msgid":"Past sessions","msgstr":["Sesiones pasadas"]},"Coaching hub":{"msgid":"Coaching hub","msgstr":["Centro de Coaching"]},"Save your spot":{"msgid":"Save your spot","msgstr":["Reserva tu lugar"]},"This feature is only available for new subscriptions. Upgrade and get personalized tips and advice.":{"msgid":"This feature is only available for new subscriptions. Upgrade and get personalized tips and advice.","msgstr":["Esta función solo está disponible para nuevas suscripciones. Mejora y obtén consejos y recomendaciones personalizadas."]},"Book now":{"msgid":"Book now","msgstr":["Reservar ahora"]},"counseling waiver":{"msgid":"counseling waiver","msgstr":["exención de asesoramiento"]},"FREE":{"msgid":"FREE","msgstr":["GRATIS"]},"Billing":{"msgid":"Billing","msgstr":["Facturación"]},"Payment method":{"msgid":"Payment method","msgstr":["Método de pago"]},"Payment history":{"msgid":"Payment history","msgstr":["Historial de pagos"]},"Invoice":{"msgid":"Invoice","msgstr":["Factura"]},"Detail":{"msgid":"Detail","msgstr":["Detalle"]},"Amount":{"msgid":"Amount","msgstr":["Monto"]},"N/A":{"msgid":"N/A","msgstr":["N/A"]},"Weight entry successfully created!":{"msgid":"Weight entry successfully created!","msgstr":["¡Entrada de peso creada con éxito!"]},"Log entry":{"msgid":"Log entry","msgstr":["Registrar entrada"]},"Ready to track your progress? Share your current weight with us below! Let\'s work towards your goals together!":{"msgid":"Ready to track your progress? Share your current weight with us below! Let\'s work towards your goals together!","msgstr":["¿Listo para rastrear tu progreso? ¡Comparte tu peso actual con nosotros a continuación! ¡Trabajemos juntos hacia tus objetivos!"]},"Date *":{"msgid":"Date *","msgstr":["Fecha *"]},"Your weight":{"msgid":"Your weight","msgstr":["Tu peso"]},"Note (optional)":{"msgid":"Note (optional)","msgstr":["Nota (opcional)"]},"Optional note":{"msgid":"Optional note","msgstr":["Nota opcional"]},"Upload":{"msgid":"Upload","msgstr":["Subir"]},"Weight entry successfully deleted!":{"msgid":"Weight entry successfully deleted!","msgstr":["¡Entrada de peso eliminada con éxito!"]},"Delete Entry":{"msgid":"Delete Entry","msgstr":["Eliminar entrada"]},"Are you sure you want to delete the next entry?":{"msgid":"Are you sure you want to delete the next entry?","msgstr":["¿Estás seguro de que deseas eliminar la siguiente entrada?"]},"Weight: ":{"msgid":"Weight: ","msgstr":["Peso: "]},"Date: ":{"msgid":"Date: ","msgstr":["Fecha: "]},"Note: ":{"msgid":"Note: ","msgstr":["Nota: "]},"Delete entry":{"msgid":"Delete entry","msgstr":["Eliminar entrada"]},"Weight entry successfully updated!":{"msgid":"Weight entry successfully updated!","msgstr":["¡Entrada de peso actualizada con éxito!"]},"Edit entry":{"msgid":"Edit entry","msgstr":["Editar entrada"]},"This modal allows you to update an existing weight entry. Modify the weight value, date, or note as needed.":{"msgid":"This modal allows you to update an existing weight entry. Modify the weight value, date, or note as needed.","msgstr":["Este modal te permite actualizar una entrada de peso existente. Modifica el valor del peso, la fecha o la nota según sea necesario."]},"Please, confirm your password":{"msgid":"Please, confirm your password","msgstr":["Por favor, confirma tu contraseña"]},"At Fridays, protecting your information is a top priority.":{"msgid":"At Fridays, protecting your information is a top priority.","msgstr":["En Fridays, proteger tu información es una prioridad."]},"We have added an additional layer of authentication to our log in.":{"msgid":"We have added an additional layer of authentication to our log in.","msgstr":["Hemos añadido una capa adicional de autenticación a nuestro inicio de sesión."]},"Please create and verify a new password.":{"msgid":"Please create and verify a new password.","msgstr":["Por favor, crea y verifica una nueva contraseña."]},"Save":{"msgid":"Save","msgstr":["Guardar"]},"I authorize the use of this credit card for subscriptions, medications and lab charges":{"msgid":"I authorize the use of this credit card for subscriptions, medications and lab charges","msgstr":["Autorizo el uso de esta tarjeta de crédito/débito para los cargos de mis suscripciones, medicamentos y laboratorio"]},"Document successfully updated!":{"msgid":"Document successfully updated!","msgstr":["¡Documento actualizado con éxito!"]},"Edit ${ lowerCaseFolderLabel }":{"msgid":"Edit ${ lowerCaseFolderLabel }","msgstr":["Editar ${ lowerCaseFolderLabel }"]},"Discard change":{"msgid":"Discard change","msgstr":["Descartar cambio"]},"Save change":{"msgid":"Save change","msgstr":["Guardar cambio"]},"Add lab test":{"msgid":"Add lab test","msgstr":["Agregar prueba de laboratorio"]},"Upload your lab tests!":{"msgid":"Upload your lab tests!","msgstr":["¡Sube tus pruebas de laboratorio!"]},"Add previous prescription":{"msgid":"Add previous prescription","msgstr":["Agregar prescripción anterior"]},"Document successfully deleted!":{"msgid":"Document successfully deleted!","msgstr":["¡Documento eliminado con éxito!"]},"Are you sure you want to remove the next file?":{"msgid":"Are you sure you want to remove the next file?","msgstr":["¿Estás seguro de que deseas eliminar el siguiente archivo?"]},"Keep file":{"msgid":"Keep file","msgstr":["Mantener archivo"]},"Remove file":{"msgid":"Remove file","msgstr":["Eliminar archivo"]},"This modal provides a preview of the selected document, allowing you to view its content without downloading":{"msgid":"This modal provides a preview of the selected document, allowing you to view its content without downloading","msgstr":["Este modal proporciona una vista previa del documento seleccionado, permitiéndote ver su contenido sin descargarlo"]},"Preview Document":{"msgid":"Preview Document","msgstr":["Vista previa del documento"]},"Can\'t view the file correctly? Open it ":{"msgid":"Can\'t view the file correctly? Open it ","msgstr":["¿No puedes ver el archivo correctamente? Ábrelo "]},"here":{"msgid":"here","msgstr":["aquí"]},"Oops! Something went wrong":{"msgid":"Oops! Something went wrong","msgstr":["¡Ups! Algo salió mal"]},"We couldn\'t generate a preview for this file. Please try refreshing the page or come back later. If the issue persists, feel free to contact our support team.":{"msgid":"We couldn\'t generate a preview for this file. Please try refreshing the page or come back later. If the issue persists, feel free to contact our support team.","msgstr":["No pudimos generar una vista previa para este archivo. Por favor, intenta actualizar la página o vuelve más tarde. Si el problema persiste, no dudes en contactar a nuestro equipo de soporte."]},"Go back to Coaching Hub":{"msgid":"Go back to Coaching Hub","msgstr":["Regresar al Centro de Coaching"]},"Go back to Document Center":{"msgid":"Go back to Document Center","msgstr":["Regresar al Centro de Documentos"]},"Try again":{"msgid":"Try again","msgstr":["Intenta de nuevo"]},"It appears that Fridays may not be the best fit for you at the moment":{"msgid":"It appears that Fridays may not be the best fit for you at the moment","msgstr":["Parece que Fridays puede no ser la mejor opción para ti en este momento"]},"While Fridays may not align with your current needs, it\'s just the beginning of discovering what works best for you. Get in touch with us so we can provide some guidance.":{"msgid":"While Fridays may not align with your current needs, it\'s just the beginning of discovering what works best for you. Get in touch with us so we can provide some guidance.","msgstr":["Aunque Fridays puede no alinearse con tus necesidades actuales, es solo el comienzo de descubrir lo que mejor funciona para ti. Ponte en contacto con nosotros para que podamos brindarte orientación."]},"Contact Fridays support":{"msgid":"Contact Fridays support","msgstr":["Contacta al soporte de Fridays"]},"Medication refills":{"msgid":"Medication refills","msgstr":["Recargas de medicamentos"]},"Your provider will review your responses and prescribe as appropriate. Simply fill out the following intake without the need to schedule an appointment! We will reach out if we have any questions.":{"msgid":"Your provider will review your responses and prescribe as appropriate. Simply fill out the following intake without the need to schedule an appointment! We will reach out if we have any questions.","msgstr":["Tu profesional de la salud revisará tus respuestas y prescribirá según sea apropiado. Simplemente completa la siguiente intake sin necesidad de programar una cita. Nos pondremos en contacto si tenemos alguna pregunta."]},"Your refill will be approved between 2-3 business days after completing this form.":{"msgid":"Your refill will be approved between 2-3 business days after completing this form.","msgstr":["Tu recarga será aprobada entre 2-3 días hábiles después de completar este formulario."]},"Redirecting to video consultation":{"msgid":"Redirecting to video consultation","msgstr":["Redirigiendo a la video-consulta"]},"Based on your form responses, we\'re guiding you to schedule a video consultation. Get ready to connect with your provider and discuss your needs!":{"msgid":"Based on your form responses, we\'re guiding you to schedule a video consultation. Get ready to connect with your provider and discuss your needs!","msgstr":["Basado en tus respuestas del formulario, te estamos guiando para programar una video-consulta. ¡Prepárate para conectarte con tu profesional de la salud y discutir tus necesidades!"]},"Video-consultation Needed":{"msgid":"Video-consultation Needed","msgstr":["Se necesita video-consulta"]},"Hi there! Based on your responses, we can\'t process your refill request right now. You\'ll need to have a video consultation with a provider.":{"msgid":"Hi there! Based on your responses, we can\'t process your refill request right now. You\'ll need to have a video consultation with a provider.","msgstr":["¡Hola! Basado en tus respuestas, no podemos procesar tu solicitud de recarga en este momento. Necesitarás tener una video-consulta con un profesional de la salud."]},"But good news! You already have a video consultation scheduled for this week. You can discuss your situation during that appointment.":{"msgid":"But good news! You already have a video consultation scheduled for this week. You can discuss your situation during that appointment.","msgstr":["¡Pero buenas noticias! Ya tienes una video-consulta programada para esta semana. Puedes discutir tu situación durante esa cita."]},"You might need urgent care":{"msgid":"You might need urgent care","msgstr":["Podrías necesitar atención urgente"]},"It seems your needs require more specialized attention than what we currently offer. Please seek care immediately at the nearest ER or urgent care in your community for the specific assistance you require.":{"msgid":"It seems your needs require more specialized attention than what we currently offer. Please seek care immediately at the nearest ER or urgent care in your community for the specific assistance you require.","msgstr":["Parece que tus necesidades requieren atención más especializada de la que actualmente ofrecemos. Por favor, busca atención de inmediato en la sala de emergencias más cercana o en un centro de atención urgente en tu comunidad para la asistencia específica que requieres."]},"Video Consultations":{"msgid":"Video Consultations","msgstr":["Video-consultas"]},"You will schedule an appointment to be seen by your provider.":{"msgid":"You will schedule an appointment to be seen by your provider.","msgstr":["Programarás una cita para ser atendido por tu profesional de la salud."]},"They will review the intake information live with you and discuss next steps on your weight management journey!":{"msgid":"They will review the intake information live with you and discuss next steps on your weight management journey!","msgstr":["Revisarán la información de intake en vivo contigo y discutirán los próximos pasos en tu camino hacia el manejo de peso."]},"If you already have your follow up scheduled you don\'t have to schedule a new session":{"msgid":"If you already have your follow up scheduled you don\'t have to schedule a new session","msgstr":["Si ya tienes tu seguimiento programado, no necesitas programar una nueva sesión."]},"Prioritizing your well-being":{"msgid":"Prioritizing your well-being","msgstr":["Priorizando tu bienestar"]},"To assist you further, we\'ve compiled a list of resources tailored to your potential needs and concerns mentioned during your visit:":{"msgid":"To assist you further, we\'ve compiled a list of resources tailored to your potential needs and concerns mentioned during your visit:","msgstr":["Para ayudarte más, hemos compilado una lista de recursos adaptados a tus posibles necesidades y preocupaciones mencionadas durante tu visita:"]},"Phone call":{"msgid":"Phone call","msgstr":["Llamada telefónica"]},"988 - Crisis Support Lifeline":{"msgid":"988 - Crisis Support Lifeline","msgstr":["988 - Línea de Apoyo en Crisis"]},"1-800-273-8255 - National Crisis Support":{"msgid":"1-800-273-8255 - National Crisis Support","msgstr":["1-800-273-8255 - Apoyo Nacional en Crisis"]},"1-866-488-7386 or text START to 678678. A national 24-hour, toll free confidential suicide hotline for LGBTQ youth":{"msgid":"1-866-488-7386 or text START to 678678. A national 24-hour, toll free confidential suicide hotline for LGBTQ youth","msgstr":["1-866-488-7386 o envía un mensaje de texto con START al 678678. Una línea nacional de prevención del suicidio confidencial y gratuita para jóvenes LGBTQ disponible las 24 horas."]},"Text":{"msgid":"Text","msgstr":["Texto"]},"Text MHA to 741741 and you will be connected to a trained Crisis Counselor. Crisis Text Line provides free, text-based support 24/7.":{"msgid":"Text MHA to 741741 and you will be connected to a trained Crisis Counselor. Crisis Text Line provides free, text-based support 24/7.","msgstr":["Envía un mensaje de texto con MHA al 741741 y serás conectado con un Consejero de Crisis capacitado. Crisis Text Line proporciona apoyo gratuito basado en texto las 24 horas, los 7 días de la semana."]},"Text 988 for immediate assistance.":{"msgid":"Text 988 for immediate assistance.","msgstr":["Envía un mensaje de texto con 988 para asistencia inmediata."]},"988 Lifeline Chat Online":{"msgid":"988 Lifeline Chat Online","msgstr":["Chat en Línea de la Línea 988"]},"988 Lifeline":{"msgid":"988 Lifeline","msgstr":["Línea 988"]},"The Trevor Project":{"msgid":"The Trevor Project","msgstr":["El Proyecto Trevor"]},"Reduced cost in-person therapy in your area:":{"msgid":"Reduced cost in-person therapy in your area:","msgstr":["Terapia en persona a costo reducido en tu área:"]},"Open Path Collective: Find your therapist":{"msgid":"Open Path Collective: Find your therapist","msgstr":["Open Path Collective: Encuentra tu terapeuta"]},"Find an in-person provider in your local area:":{"msgid":"Find an in-person provider in your local area:","msgstr":["Encuentra un profesional de la salud en persona en tu área local:"]},"Psychology Today US":{"msgid":"Psychology Today US","msgstr":["Psychology Today US"]},"Subscription options available":{"msgid":"Subscription options available","msgstr":["Opciones de suscripción disponibles"]},"send us a message":{"msgid":"send us a message","msgstr":["envíanos un mensaje"]},"Changing subscription":{"msgid":"Changing subscription","msgstr":["Cambiando suscripción"]},"You\'re about to change your subscription to receive the necessary medication. Are you sure?":{"msgid":"You\'re about to change your subscription to receive the necessary medication. Are you sure?","msgstr":["Estás a punto de cambiar tu suscripción para recibir el medicamento necesario. ¿Estás seguro?"]},"Confirm change":{"msgid":"Confirm change","msgstr":["Confirmar cambio"]},"Your card information has been successfully updated":{"msgid":"Your card information has been successfully updated","msgstr":["La información de tu tarjeta ha sido actualizada con éxito"]},"Edit your payment method":{"msgid":"Edit your payment method","msgstr":["Editar tu método de pago"]},"Keep current subscription":{"msgid":"Keep current subscription","msgstr":["Mantener suscripción actual"]},"Keep my subscription":{"msgid":"Keep my subscription","msgstr":["Mantener mi suscripción"]},"To continue, please check the \\"I agree\\" box":{"msgid":"To continue, please check the \\"I agree\\" box","msgstr":["Para continuar, por favor marca la casilla \\"Estoy de acuerdo\\""]},"I agree to the new charge and understand that I cannot revert to my current subscription":{"msgid":"I agree to the new charge and understand that I cannot revert to my current subscription","msgstr":["Acepto el nuevo cargo y entiendo que no puedo volver a mi suscripción actual"]},"Subscription plan successfully updated!":{"msgid":"Subscription plan successfully updated!","msgstr":["¡Plan de suscripción actualizado con éxito!"]},"Home":{"msgid":"Home","msgstr":["Inicio"]},"Oops seems like something went wrong":{"msgid":"Oops seems like something went wrong","msgstr":["Ups, parece que algo salió mal"]},"Pending":{"msgid":"Pending","msgstr":["Pendiente"]},"Paid":{"msgid":"Paid","msgstr":["Pagado"]},"On its way":{"msgid":"On its way","msgstr":["En camino"]},"Canceled":{"msgid":"Canceled","msgstr":["Cancelado"]},"Denied":{"msgid":"Denied","msgstr":["Denegado"]},"Branded":{"msgid":"Branded","msgstr":["De marca"]},"Include at least 8 characters.":{"msgid":"Include at least 8 characters.","msgstr":["Incluye al menos 8 caracteres."]},"Incorporate numbers (0-9).":{"msgid":"Incorporate numbers (0-9).","msgstr":["Incorpora números (0-9)."]},"Utilize special characters (e.g., !, @, #, $, %, etc).":{"msgid":"Utilize special characters (e.g., !, @, #, $, %, etc).","msgstr":["Utiliza caracteres especiales (por ejemplo, !, @, #, $, %, etc.)."]},"Avoid common phrases like \\"password,\\" \\"123456,\\" or \\"qwerty.\\"":{"msgid":"Avoid common phrases like \\"password,\\" \\"123456,\\" or \\"qwerty.\\"","msgstr":["Evita frases comunes como \\"contraseña,\\" \\"123456,\\" o \\"qwerty.\\""]},"Include a mix of uppercase and lowercase letters.":{"msgid":"Include a mix of uppercase and lowercase letters.","msgstr":["Incluye una mezcla de letras mayúsculas y minúsculas."]},"Lab test here":{"msgid":"Lab test here","msgstr":["Prueba de laboratorio aquí"]},"Previous prescriptions here":{"msgid":"Previous prescriptions here","msgstr":["Prescripciones anteriores aquí"]},"Medical records here":{"msgid":"Medical records here","msgstr":["Registros médicos aquí"]},"Test name":{"msgid":"Test name","msgstr":["Nombre de la prueba"]},"Prescription name":{"msgid":"Prescription name","msgstr":["Nombre de la prescripción"]},"Record name":{"msgid":"Record name","msgstr":["Nombre del registro"]},"lab tests":{"msgid":"lab tests","msgstr":["pruebas de laboratorio"]},"prescriptions":{"msgid":"prescriptions","msgstr":["prescripciones"]},"medical records":{"msgid":"medical records","msgstr":["registros médicos"]},"Weight Progress Tracker":{"msgid":"Weight Progress Tracker","msgstr":["Seguimiento del Progreso de Peso"]},"Log data":{"msgid":"Log data","msgstr":["Registrar datos"]},"No entries for this period yet":{"msgid":"No entries for this period yet","msgstr":["No hay entradas para este período aún"]},"Record your weight entry with the “Log data” button to begin tracking your progress.":{"msgid":"Record your weight entry with the “Log data” button to begin tracking your progress.","msgstr":["Registra tu entrada de peso con el botón “Registrar datos” para comenzar a rastrear tu progreso."]},"Edit document name":{"msgid":"Edit document name","msgstr":["Editar nombre del documento"]},"Remove document":{"msgid":"Remove document","msgstr":["Eliminar documento"]},"There are no upcoming consultations yet":{"msgid":"There are no upcoming consultations yet","msgstr":["No hay consultas pendientes"]},"Join now":{"msgid":"Join now","msgstr":["Unirse"]},"Compounded":{"msgid":"Compounded","msgstr":["Compuesto"]},"ones":{"msgid":"ones","msgstr":[" "]},"The highlighted dates are the available ${ availability }":{"msgid":"The highlighted dates are the available ${ availability }","msgstr":["Las fechas resaltadas son las disponibles ${ availability }"]},"Our team is already working on fixing it.":{"msgid":"Our team is already working on fixing it.","msgstr":["Nuestro equipo ya está trabajando en solucionarlo."]},"Try to select another date.":{"msgid":"Try to select another date.","msgstr":["Intenta seleccionar otra fecha."]},"Thank you for your patience!":{"msgid":"Thank you for your patience!","msgstr":["¡Gracias por tu paciencia!"]},"Choose a date to view available times":{"msgid":"Choose a date to view available times","msgstr":["Elige una fecha para ver los horarios disponibles"]}," on ${ verboseSelectedDate }":{"msgid":" on ${ verboseSelectedDate }","msgstr":[" en ${ verboseSelectedDate }"]},"Confirm Consultation":{"msgid":"Confirm Consultation","msgstr":["Confirmar Consulta"]},"This answer divert to video consultation":{"msgid":"This answer divert to video consultation","msgstr":["Esta respuesta redirige a video-consulta"]},"Please indicate any relevant medical history or conditions from the following list":{"msgid":"Please indicate any relevant medical history or conditions from the following list","msgstr":["Por favor, indica cualquier historial médico relevante o condiciones de la siguiente lista"]},"Drug or Alcohol Misuse":{"msgid":"Drug or Alcohol Misuse","msgstr":["Abuso de drogas o alcohol"]},"History of thyroid issues or cancer in you or your family?":{"msgid":"History of thyroid issues or cancer in you or your family?","msgstr":["¿Historia de problemas de tiroides o cáncer en ti o en tu familia?"]},"Thyroid cyst/nodule, medullary thyroid carcinoma, or multiple endocrine neoplasia syndrome type 2":{"msgid":"Thyroid cyst/nodule, medullary thyroid carcinoma, or multiple endocrine neoplasia syndrome type 2","msgstr":["Quiste/nódulo tiroideo, carcinoma medular de tiroides o síndrome de neoplasia endocrina múltiple tipo 2"]},"Tumor or infection in your brain or spinal cord":{"msgid":"Tumor or infection in your brain or spinal cord","msgstr":["Tumor o infección en tu cerebro o médula espinal"]},"Elevated resting heart rate or a diagnosis of tachycardia":{"msgid":"Elevated resting heart rate or a diagnosis of tachycardia","msgstr":["Frecuencia cardíaca en reposo elevada o diagnóstico de taquicardia"]},"Coronary artery disease, stroke, or recent heart attack":{"msgid":"Coronary artery disease, stroke, or recent heart attack","msgstr":["Enfermedad arterial coronaria, accidente cerebrovascular o infarto reciente"]},"By recent we mean the last 24 months.":{"msgid":"By recent we mean the last 24 months.","msgstr":["Por reciente nos referimos a los últimos 24 meses."]},"History of congestive heart failure":{"msgid":"History of congestive heart failure","msgstr":["Historia de insuficiencia cardíaca congestiva"]},"Recent hospitalization within the last 12 months":{"msgid":"Recent hospitalization within the last 12 months","msgstr":["Hospitalización reciente en los últimos 12 meses"]},"What is your current or average blood pressure range?":{"msgid":"What is your current or average blood pressure range?","msgstr":["¿Cuál es tu rango de presión arterial actual o promedio?"]},"Normal":{"msgid":"Normal","msgstr":["Normal"]},"Elevated":{"msgid":"Elevated","msgstr":["Elevado"]},"High stage 1":{"msgid":"High stage 1","msgstr":["Alto etapa 1"]},"High Stage 2":{"msgid":"High Stage 2","msgstr":["Alto etapa 2"]},"What is your current or average heart rate range?":{"msgid":"What is your current or average heart rate range?","msgstr":["¿Cuál es tu rango de frecuencia cardíaca actual o promedio?"]},"Slow":{"msgid":"Slow","msgstr":["Lento"]},"Slightly fast":{"msgid":"Slightly fast","msgstr":["Ligeramente rápido"]},"Fast":{"msgid":"Fast","msgstr":["Rápido"]},"Are you currently taking, plan to take, or have recently taken opiate pain medications and/or opiate-based street drugs?":{"msgid":"Are you currently taking, plan to take, or have recently taken opiate pain medications and/or opiate-based street drugs?","msgstr":["¿Estás tomando actualmente, planeas tomar o has tomado recientemente medicamentos para el dolor opioides y/o drogas callejeras basadas en opioides?"]},"(within the last 3 months)":{"msgid":"(within the last 3 months)","msgstr":["(en los últimos 3 meses)"]},"Yes":{"msgid":"Yes","msgstr":["Sí"]},"No":{"msgid":"No","msgstr":["No"]},"Are you currently taking or have previously taken medication(s) for weight loss?":{"msgid":"Are you currently taking or have previously taken medication(s) for weight loss?","msgstr":["¿Estás tomando actualmente o has tomado anteriormente medicamentos para la pérdida de peso?"]},"Do you need medication?":{"msgid":"Do you need medication?","msgstr":["¿Necesitas medicamento?"]},"Tracking #${ medicationRequest.trackingNumber }":{"msgid":"Tracking #${ medicationRequest.trackingNumber }","msgstr":["Seguimiento #${ medicationRequest.trackingNumber }"]},"New medication request":{"msgid":"New medication request","msgstr":["Nueva solicitud"]},"Your request has been sent to your provider, it will take a few days for them to review it.":{"msgid":"Your request has been sent to your provider, it will take a few days for them to review it.","msgstr":["Tu solicitud ha sido enviada a tu profesional de la salud, tomará unos días para que la revisen."]},"The medication has been approved and charged to your account. It is being prepared for delivery.":{"msgid":"The medication has been approved and charged to your account. It is being prepared for delivery.","msgstr":["El medicamento ha sido aprobado y cargado a tu cuenta. Está siendo preparado para la entrega."]},"Your medication is on its way to your address.":{"msgid":"Your medication is on its way to your address.","msgstr":["Tu medicamento está en camino a tu dirección."]},"The request has been canceled. Please reach out to our support team for further clarification.":{"msgid":"The request has been canceled. Please reach out to our support team for further clarification.","msgstr":["La solicitud ha sido cancelada. Por favor, contacta a nuestro equipo de soporte para más aclaraciones."]},"Your order process has been completed. For any inquiries, reach out to our support team.":{"msgid":"Your order process has been completed. For any inquiries, reach out to our support team.","msgstr":["El proceso de tu pedido ha sido completado. Para cualquier consulta, contacta a nuestro equipo de soporte."]},"Unfortunately, your request has been denied. Please reach out to our support team for further assistance.":{"msgid":"Unfortunately, your request has been denied. Please reach out to our support team for further assistance.","msgstr":["Desafortunadamente, tu solicitud ha sido denegada. Por favor, contacta a nuestro equipo de soporte para más ayuda."]},"Your provider has ordered branded medication. It will be sent to your local pharmacy":{"msgid":"Your provider has ordered branded medication. It will be sent to your local pharmacy","msgstr":["Tu profesional de la salud ha ordenado un medicamento de marca. Será enviado a tu farmacia local."]},"There was an error, and the file couldn\'t be uploaded correctly.":{"msgid":"There was an error, and the file couldn\'t be uploaded correctly.","msgstr":["Hubo un error y el archivo no pudo ser subido correctamente."]},"Monthly View":{"msgid":"Monthly View","msgstr":["Vista Mensual"]},"Yearly View":{"msgid":"Yearly View","msgstr":["Vista Anual"]},"Male":{"msgid":"Male","msgstr":["Masculino"]},"Female":{"msgid":"Female","msgstr":["Femenino"]},"Eastern Time":{"msgid":"Eastern Time","msgstr":["Hora del Este (ET)"]},"Central Time":{"msgid":"Central Time","msgstr":["Hora Central (CT)"]},"Mountain Time":{"msgid":"Mountain Time","msgstr":["Hora Montaña (MT)"]},"Pacific Time":{"msgid":"Pacific Time","msgstr":["Hora del Pacífico (PT)"]},"Arizona Time":{"msgid":"Arizona Time","msgstr":["Hora de Arizona"]},"Alaska Time":{"msgid":"Alaska Time","msgstr":["Hora de Alaska"]},"Hawaii Time":{"msgid":"Hawaii Time","msgstr":["Hora de Hawái"]},"Credit card is required":{"msgid":"Credit card is required","msgstr":["Ingrese tarjeta de crédito/débito"]},"Unfortunately, the behavioral health history that you have identified is not considered to be best practice when treated through telehealth.":{"msgid":"Unfortunately, the behavioral health history that you have identified is not considered to be best practice when treated through telehealth.","msgstr":["Desafortunadamente, la historia de salud conductual que ha identificado no se considera la mejor práctica cuando se trata a través de la telemedicina."]},"Our commitment is to ensure you receive the most appropriate and evidence-based care from our team of medical professionals. ${ telehealthBestPracticesWarning }\\n${ newLine }\\nIn such cases, prioritizing your safety, we recommend seeking care from a trusted local provider for more beneficial results. We apologize for any inconvenience this may cause and truly value the opportunity you\'ve given us to support you.":{"msgid":"Our commitment is to ensure you receive the most appropriate and evidence-based care from our team of medical professionals. ${ telehealthBestPracticesWarning }\\n${ newLine }\\nIn such cases, prioritizing your safety, we recommend seeking care from a trusted local provider for more beneficial results. We apologize for any inconvenience this may cause and truly value the opportunity you\'ve given us to support you.","msgstr":["Nuestro compromiso es garantizar que reciba la atención más adecuada y basada en evidencia de nuestro equipo de profesionales de la salud. ${ telehealthBestPracticesWarning }\\n${ newLine }\\nEn tales casos, priorizando su seguridad, recomendamos buscar atención de un proveedor local de confianza para obtener resultados más beneficiosos. Nos disculpamos por cualquier inconveniente que esto pueda causar y realmente valoramos la oportunidad que nos ha brindado para apoyarle."]},"File required, try again or remove it":{"msgid":"File required, try again or remove it","msgstr":["Ingrese un archivo, intente nuevamente o elimínelo"]},"Id is required":{"msgid":"Id is required","msgstr":["Ingrese identificación"]},"Date is required":{"msgid":"Date is required","msgstr":["La fecha es requerida"]},"(or suicidal thoughts)":{"msgid":"(or suicidal thoughts)","msgstr":["(o pensamientos suicidas)"]},"Check our FAQs":{"msgid":"Check our FAQs","msgstr":["Consulte nuestras preguntas frecuentes"]},"Send us a message":{"msgid":"Send us a message","msgstr":["Envíenos un mensaje"]},"Remove ${ documentLabel }":{"msgid":"Remove ${ documentLabel }","msgstr":["Eliminar ${ documentLabel }"]},"Save ${ documentLabel }":{"msgid":"Save ${ documentLabel }","msgstr":["Guardar ${ documentLabel }"]},"This field is required":{"msgid":"This field is required","msgstr":["Este campo es obligatorio"]},"Your dietitian notes, medical records and more.":{"msgid":"Your dietitian notes, medical records and more.","msgstr":["Sus notas del dietista, registros médicos y más."]},"These are the available consultations based on your language preference. If you\'d like, you can change your preferred language for the consultation by clicking ${ selectorOpener }.":{"msgid":"These are the available consultations based on your language preference. If you\'d like, you can change your preferred language for the consultation by clicking ${ selectorOpener }.","msgstr":["Estas son las consultas disponibles según su preferencia de idioma. Si lo desea, puede cambiar su idioma preferido para la consulta haciendo clic ${ selectorOpener }."]},"on ${ provider.fullName } calendar":{"msgid":"on ${ provider.fullName } calendar","msgstr":["en el calendario de ${ provider.fullName }"]},"1. Choose an available day:":{"msgid":"1. Choose an available day:","msgstr":["1. Elija un día disponible:"]},"Consultation language preference":{"msgid":"Consultation language preference","msgstr":["Preferencia de idioma para la consulta"]},"1. Language preference":{"msgid":"1. Language preference","msgstr":["1. Preferencia de idioma"]},"Provider preference":{"msgid":"Provider preference","msgstr":["Preferencia del profesional"]},"Earliest available":{"msgid":"Earliest available","msgstr":["Primera disponibilidad"]},"Choose a provider":{"msgid":"Choose a provider","msgstr":["Elija un profesional"]},"Select provider":{"msgid":"Select provider","msgstr":["Seleccione un profesional"]},"Loading providers...":{"msgid":"Loading providers...","msgstr":["Cargando profesionales..."]},"Select a provider":{"msgid":"Select a provider","msgstr":["Seleccione un profesional"]},"Available 10 minutes before your session.":{"msgid":"Available 10 minutes before your session.","msgstr":["Disponible 10 minutos antes de su sesión."]},"Access to 1:1 nutritional counseling sessions":{"msgid":"Access to 1:1 nutritional counseling sessions","msgstr":["Acceso a sesiones de asesoramiento nutricional 1 a 1"]},"Contact support":{"msgid":"Contact support","msgstr":["Contactar soporte"]},"Go to Shop":{"msgid":"Go to Shop","msgstr":["Ir a la Tienda"]},"Please try again or reach out to support if this issue continue.":{"msgid":"Please try again or reach out to support if this issue continue.","msgstr":["Por favor, intenta de nuevo o contacta al soporte si este problema persiste."]},"will take effect starting from your next billing period":{"msgid":"will take effect starting from your next billing period","msgstr":["entrará en vigencia a partir de su próximo periodo de facturación"]},"No commitment - cancel anytime!":{"msgid":"No commitment - cancel anytime!","msgstr":["¡Sin compromiso - cancela en cualquier momento!"]},"Any changes to your subscription plan ${ takeEffectStrong }. This means that your current plan will remain active until the end of the current billing cycle. ${ noCommitmentStrong }":{"msgid":"Any changes to your subscription plan ${ takeEffectStrong }. This means that your current plan will remain active until the end of the current billing cycle. ${ noCommitmentStrong }","msgstr":["Cualquier cambio en tu plan de suscripción ${ takeEffectStrong }. Esto significa que tu plan actual seguirá activo hasta el final del ciclo de facturación actual. ${ noCommitmentStrong }"]},"I agree to the new charge associated with my subscription and understand the changes in pricing":{"msgid":"I agree to the new charge associated with my subscription and understand the changes in pricing","msgstr":["Acepto el nuevo cargo asociado con mi suscripción y entiendo los cambios en los precios"]},"bundle":{"msgid":"bundle","msgstr":["paquete"]},"monthly":{"msgid":"monthly","msgstr":["mensual"]},"You\'ve already requested a ${ nextPeriodPlanChangeStrong }. If you\'d like to make another change, just go ahead!":{"msgid":"You\'ve already requested a ${ nextPeriodPlanChangeStrong }. If you\'d like to make another change, just go ahead!","msgstr":["Ya has solicitado un ${ nextPeriodPlanChangeStrong }. Si deseas hacer otro cambio, ¡adelante!"]},"Current subscription":{"msgid":"Current subscription","msgstr":["Suscripción actual"]},"Supply":{"msgid":"Supply","msgstr":["Suministro"]},"How many doses of the current level of medication do you have left?":{"msgid":"How many doses of the current level of medication do you have left?","msgstr":["¿Cuántas dosis del nivel actual de medicación le quedan?"]},"Almost there!":{"msgid":"Almost there!","msgstr":["Casi llegamos!"]},"Got it, back to My Meds":{"msgid":"Got it, back to My Meds","msgstr":["Entendido, volvemos a Mis medicamentos"]},"Just a friendly reminder":{"msgid":"Just a friendly reminder","msgstr":["Solo un recordatorio"]},"Proceed anyway":{"msgid":"Proceed anyway","msgstr":["Continuar de todos modos"]},"Approved":{"msgid":"Approved","msgstr":["Aprobado"]},"The medication request has been approved by your provider.":{"msgid":"The medication request has been approved by your provider.","msgstr":["La solicitud de medicamento ha sido aprobada por su profesional de la salud."]},"After the first ${ durationInMonths }month(s), your subscription will change to ${ planPrice } every ${ monthsDuration }":{"msgid":"After the first ${ durationInMonths }month(s), your subscription will change to ${ planPrice } every ${ monthsDuration }","msgstr":["Luego de el/los primero(s) ${ durationInMonths }mes(es), tu suscripcion cambiara a ${ planPrice } cada ${ monthsDuration }"]},"Invalid day":{"msgid":"Invalid day","msgstr":["Día inválido"]},"Invalid month":{"msgid":"Invalid month","msgstr":["Mes inválido"]},"Invalid year":{"msgid":"Invalid year","msgstr":["Año inválido"]},"Invalid day for the selected month":{"msgid":"Invalid day for the selected month","msgstr":["Día inválido para el mes seleccionado"]},"Please select your journey":{"msgid":"Please select your journey","msgstr":["Por favor, seleccione su camino"]},"MM":{"msgid":"MM","msgstr":["MM"]},"DD":{"msgid":"DD","msgstr":["DD"]},"YYYY":{"msgid":"YYYY","msgstr":["AAAA"]},"Update payment":{"msgid":"Update payment","msgstr":["Actualizar pago"]},"Start your journey":{"msgid":"Start your journey","msgstr":["Comience su camino"]},"Order meds without video visit":{"msgid":"Order meds without video visit","msgstr":["Ordenar medicamentos sin consulta por video"]},"Order meds with video visit":{"msgid":"Order meds with video visit","msgstr":["Ordenar medicamentos con consulta por video"]},"You are creating an account for the email ${ email }":{"msgid":"You are creating an account for the email ${ email }","msgstr":["Está creando una cuenta para el correo electrónico ${ email }"]},"Main info":{"msgid":"Main info","msgstr":["Información principal"]},"Country is required":{"msgid":"Country is required","msgstr":["El país es obligatorio"]},"Address":{"msgid":"Address","msgstr":["Dirección"]},"Zip code must be in the format 12345 or 12345-6789":{"msgid":"Zip code must be in the format 12345 or 12345-6789","msgstr":["El código postal debe estar en el formato 12345 o 12345-6789"]},"Please select your preferred language":{"msgid":"Please select your preferred language","msgstr":["Por favor, seleccione su idioma de preferencia"]},"Invalid language type":{"msgid":"Invalid language type","msgstr":["Tipo de idioma inválido"]},"It looks like you\'re outside the age range for Fridays":{"msgid":"It looks like you\'re outside the age range for Fridays","msgstr":["Parece que estás fuera del rango de edad para Fridays."]},"You\'re now part of the Fridays Coaching crew!":{"msgid":"You\'re now part of the Fridays Coaching crew!","msgstr":["¡Ahora eres parte del equipo de Fridays Coaching!"]},"Congratulations! We\'re thrilled to support you on your wellness journey. Let\'s make every day feel like a Friday! 🎉":{"msgid":"Congratulations! We\'re thrilled to support you on your wellness journey. Let\'s make every day feel like a Friday! 🎉","msgstr":["¡Felicidades! Estamos encantados de ayudarte en tu viaje de bienestar. ¡Hagamos que cada día parezca un viernes! 🎉"]},"Explore Coaching sessions":{"msgid":"Explore Coaching sessions","msgstr":["Explora las sesiones de coaching"]},"Have you received your medication?":{"msgid":"Have you received your medication?","msgstr":["¿Has recibido tu medicamento?"]},"Coaching lab":{"msgid":"Coaching lab","msgstr":["Coaching lab"]},"Draft":{"msgid":"Draft","msgstr":["Borrador"]},"Nutrition":{"msgid":"Nutrition","msgstr":["Nutrición"]},"Mindset":{"msgid":"Mindset","msgstr":["Mentalidad"]},"Movement flow":{"msgid":"Movement flow","msgstr":["Movimiento"]},"Support group":{"msgid":"Support group","msgstr":["Grupo de apoyo"]},"Checking status":{"msgid":"Checking status","msgstr":["Revisando estado"]},"We\'re checking on the delivery status of your medication, and will let you know you as soon as we have an answer.":{"msgid":"We\'re checking on the delivery status of your medication, and will let you know you as soon as we have an answer.","msgstr":["Estamos comprobando el estado de tu envío, y te notificaremos en cuanto tengamos una respuesta."]},"View, manage, and upload your health documents easily.":{"msgid":"View, manage, and upload your health documents easily.","msgstr":["Visualiza, gestiona y sube tus documentos de salud fácilmente."]},"Select...":{"msgid":"Select...","msgstr":["Seleccionar..."]},"Archived":{"msgid":"Archived","msgstr":["Archivado"]},"We didn\'t receive any information if the medication was delivered or not":{"msgid":"We didn\'t receive any information if the medication was delivered or not","msgstr":["No hemos recibido información sobre si el medicamento fue entregado."]},"Title":{"msgid":"Title","msgstr":["Título"]},"E.g. Emotional hunger":{"msgid":"E.g. Emotional hunger","msgstr":["Ej. Hambre emocional"]},"Edit session":{"msgid":"Edit session","msgstr":["Editar sesión"]},"Delete":{"msgid":"Delete","msgstr":["Eliminar"]},"Publish":{"msgid":"Publish","msgstr":["Publicar"]},"Required fields *":{"msgid":"Required fields *","msgstr":["Campos obligatorios *"]},"Create session":{"msgid":"Create session","msgstr":["Crear sesión"]},"Discard":{"msgid":"Discard","msgstr":["Descartar"]},"Save as draft":{"msgid":"Save as draft","msgstr":["Guardar borrador"]},"Upcoming sessions":{"msgid":"Upcoming sessions","msgstr":["Sesiones próximas"]},"Missed a session? No worries! You can re-watch all sessions here and stay up to date.":{"msgid":"Missed a session? No worries! You can re-watch all sessions here and stay up to date.","msgstr":["¿Te perdiste una sesión? ¡No te preocupes! Puedes volver a ver todas las sesiones aquí y mantenerte al día."]},"Coach":{"msgid":"Coach","msgstr":["Coach"]},"min":{"msgid":"min","msgstr":["min"]},"Unregister":{"msgid":"Unregister","msgstr":["Darse de baja"]},"Coach is required":{"msgid":"Coach is required","msgstr":["Seleccione coach"]},"Coach name is required":{"msgid":"Coach name is required","msgstr":["Ingrese nombre del coach"]},"Session successfully created!":{"msgid":"Session successfully created!","msgstr":["¡Sesión creada con éxito!"]},"Session successfully deleted!":{"msgid":"Session successfully deleted!","msgstr":["¡Sesión eliminada con éxito!"]},"You\'re all set for ${ session.title }":{"msgid":"You\'re all set for ${ session.title }","msgstr":["¡Estás listo para ${ session.title }!"]},"Booking Confirmed! ${ sessionTitle }":{"msgid":"Booking Confirmed! ${ sessionTitle }","msgstr":["¡Reserva confirmada! ${ sessionTitle }"]},"You\'ve successfully canceled your participation in ${ session.title }":{"msgid":"You\'ve successfully canceled your participation in ${ session.title }","msgstr":["Has cancelado con éxito tu participación en ${ session.title }"]},"Unsubscribed Successfully! ${ sessionTitle }":{"msgid":"Unsubscribed Successfully! ${ sessionTitle }","msgstr":["¡Dado de baja con éxito! ${ sessionTitle }"]},"Session successfully updated!":{"msgid":"Session successfully updated!","msgstr":["¡Sesión actualizada con éxito!"]},"Delete Session":{"msgid":"Delete Session","msgstr":["Eliminar Sesión"]},"You are about to delete a session that has enrolled users. Once deleted, we\'ll send them an email letting them know it\'s been canceled.\\nAre you sure you want to delete it?":{"msgid":"You are about to delete a session that has enrolled users. Once deleted, we\'ll send them an email letting them know it\'s been canceled.\\nAre you sure you want to delete it?","msgstr":["Estás a punto de eliminar una sesión que tiene usuarios inscritos. Una vez eliminada, les enviaremos un correo electrónico informándoles que ha sido cancelada.\\n¿Estás seguro de que deseas eliminarla?"]},"You are about to delete a session. Are you sure you want to proceed with the deletion?":{"msgid":"You are about to delete a session. Are you sure you want to proceed with the deletion?","msgstr":["Estás a punto de eliminar una sesión. ¿Estás seguro de que deseas continuar con la eliminación?"]},"Delete session":{"msgid":"Delete session","msgid_plural":"Delete sessions","msgstr":["Eliminar sesión","Eliminar sesiones"]},"Category":{"msgid":"Category","msgstr":["Categoría"]},"Duration":{"msgid":"Duration","msgstr":["Duración"]},"Save your spot!":{"msgid":"Save your spot!","msgstr":["¡Reserva tu lugar!"]},"By clicking the \\"Book my Spot\\" button, you are reserving your place for this session.":{"msgid":"By clicking the \\"Book my Spot\\" button, you are reserving your place for this session.","msgstr":["Al hacer clic en el botón \\"Reservar mi lugar\\", estás reservando tu sitio para esta sesión."]},"Book my Spot":{"msgid":"Book my Spot","msgstr":["Reservar mi lugar"]},"Enrolled users will appear here":{"msgid":"Enrolled users will appear here","msgstr":["Los usuarios inscritos aparecerán aquí"]},"Edit":{"msgid":"Edit","msgstr":["Editar"]},"Streamed on":{"msgid":"Streamed on","msgstr":["Transmitido el"]},"Recording":{"msgid":"Recording","msgstr":["Grabación"]},"The recording is processing":{"msgid":"The recording is processing","msgstr":["La grabación está en proceso"]},"View recording":{"msgid":"View recording","msgstr":["Ver grabación"]},"No spots left!":{"msgid":"No spots left!","msgstr":["¡No quedan lugares!"]},"Already registered!":{"msgid":"Already registered!","msgstr":["¡Ya registrado!"]},"Category is required":{"msgid":"Category is required","msgstr":["Seleccione categoría"]},"Title is required":{"msgid":"Title is required","msgstr":["Ingrese título"]},"Duration is required":{"msgid":"Duration is required","msgstr":["Seleccione duración"]},"All sessions":{"msgid":"All sessions","msgstr":["Todas"]},"Subscription update needed":{"msgid":"Subscription update needed","msgstr":["Necesitas actualizar tu subscripción"]},"What you need to know":{"msgid":"What you need to know","msgstr":["Lo que necesitas saber"]},"Must be greater than 0":{"msgid":"Must be greater than 0","msgstr":["Debe ser mayor que 0"]},"Height (feet)":{"msgid":"Height (feet)","msgstr":["Altura (pies)"]},"Height (inches)":{"msgid":"Height (inches)","msgstr":["Altura (pulgadas)"]},"Weight (pounds)":{"msgid":"Weight (pounds)","msgstr":["Peso (libras)"]},"Back to Home":{"msgid":"Back to Home","msgstr":["Volver al inicio"]},"You must agree to the terms and conditions":{"msgid":"You must agree to the terms and conditions","msgstr":["Debes aceptar los términos y condiciones"]},"Checkout":{"msgid":"Checkout","msgstr":["Finalizar compra"]},"New!":{"msgid":"New!","msgstr":["¡Nuevo!"]},"Fridays Terms and Conditions":{"msgid":"Fridays Terms and Conditions","msgstr":["Términos y condiciones de Fridays"]},"Fridays Privacy Policy":{"msgid":"Fridays Privacy Policy","msgstr":["Política de privacidad de Fridays"]},"123, Main Street":{"msgid":"123, Main Street","msgstr":["123, Calle Principal"]},"1A":{"msgid":"1A","msgstr":["1A"]},"Phoenix":{"msgid":"Phoenix","msgstr":["Phoenix"]},"Address is required":{"msgid":"Address is required","msgstr":["La dirección es obligatoria"]},"City is required":{"msgid":"City is required","msgstr":["La ciudad es obligatoria"]},"Live!":{"msgid":"Live!","msgstr":["¡En vivo!"]},"Keep browsing":{"msgid":"Keep browsing","msgstr":["Continúa explorando"]},"Continue to Checkout":{"msgid":"Continue to Checkout","msgstr":["Continuar a la Compra"]},"Looks like you haven\'t picked any products.":{"msgid":"Looks like you haven\'t picked any products.","msgstr":["Parece que no has seleccionado ningún producto."]},"Please choose at least one to continue your health journey. You can always make changes at checkout!":{"msgid":"Please choose at least one to continue your health journey. You can always make changes at checkout!","msgstr":["Por favor, elige al menos uno para continuar tu camino hacia la salud. ¡Siempre puedes hacer cambios al finalizar la compra!"]},"Looks like you haven\'t picked a product for ":{"msgid":"Looks like you haven\'t picked a product for ","msgstr":["Parece que no has elegido un producto para "]},"Please choose a treatment to continue your health journey. You can always make changes at checkout!":{"msgid":"Please choose a treatment to continue your health journey. You can always make changes at checkout!","msgstr":["Elige un tratamiento para seguir con tu plan de salud. ¡Siempre puedes modificarlo al finalizar la compra!"]},"Missing something?":{"msgid":"Missing something?","msgstr":["¿Olvidaste algo?"]},"Here\'s your summary":{"msgid":"Here\'s your summary","msgstr":["Aquí está tu resumen"]},"Remove":{"msgid":"Remove","msgstr":["Eliminar"]},"Renews in":{"msgid":"Renews in","msgstr":["Se renueva en"]},"days":{"msgid":"days","msgstr":["días"]},"We are processing your payment, just give us a moment. You\'ll be able to create your Fridays account shortly!":{"msgid":"We are processing your payment, just give us a moment. You\'ll be able to create your Fridays account shortly!","msgstr":["Estamos procesando tu pago, solo danos un momento. ¡Pronto podrás crear tu cuenta de Fridays!"]},"Enter your password":{"msgid":"Enter your password","msgstr":["Ingresa tu contraseña"]},"Confirm your password":{"msgid":"Confirm your password","msgstr":["Confirma tu contraseña"]},"Authorization is required":{"msgid":"Authorization is required","msgstr":["Se requiere autorización"]},"Sex assigned at birth is required":{"msgid":"Sex assigned at birth is required","msgstr":["El sexo asignado al nacer es obligatorio"]},"You have pending intake forms":{"msgid":"You have pending intake forms","msgstr":["Tienes formularios de admisión pendientes"]},"5 min":{"msgid":"5 min","msgstr":["5 min"]},"Incomplete":{"msgid":"Incomplete","msgstr":["Incompleto"]},"Complete":{"msgid":"Complete","msgstr":["Completar"]},"Oops! There was an error":{"msgid":"Oops! There was an error","msgstr":["¡Ups! Hubo un error"]},"Oops! It looks like there\'s been a hiccup. Not to worry, though! We\'ve already let our technical support team know, and they\'ll be reaching out to you with a solution. Thanks for your understanding!":{"msgid":"Oops! It looks like there\'s been a hiccup. Not to worry, though! We\'ve already let our technical support team know, and they\'ll be reaching out to you with a solution. Thanks for your understanding!","msgstr":["¡Ups! Parece que ha habido un inconveniente. No te preocupes, hemos informado a nuestro equipo de soporte técnico y se comunicarán contigo con una solución. ¡Gracias por tu comprensión!"]},"Back to Fridays":{"msgid":"Back to Fridays","msgstr":["Volver a Fridays"]},"Total":{"msgid":"Total","msgstr":["Total"]},"My meds":{"msgid":"My meds","msgstr":["Mis medicamentos"]},"Back to back orders":{"msgid":"Back to back orders","msgstr":["Pedidos consecutivos"]},"Your last order was placed too recently. Please wait a little longer before requesting another refill.":{"msgid":"Your last order was placed too recently. Please wait a little longer before requesting another refill.","msgstr":["Tu último pedido se realizó recientemente. Por favor, espera un poco más antes de solicitar otra recarga."]},"Please select a refillable product to proceed":{"msgid":"Please select a refillable product to proceed","msgstr":["Por favor selecciona un producto recargable para continuar"]},"You can only pick one med at a time. Once you\'re done, you can come back and grab another if you need to!":{"msgid":"You can only pick one med at a time. Once you\'re done, you can come back and grab another if you need to!","msgstr":["Solo puedes elegir un medicamento a la vez. ¡Una vez que hayas terminado, puedes volver y tomar otro si lo necesitas!"]},"Confirm and continue":{"msgid":"Confirm and continue","msgstr":["Confirmar y continuar"]},"Upcoming appointment":{"msgid":"Upcoming appointment","msgstr":["Próxima cita"]},"You have an upcoming visit with your provider. Please wait until after it before requesting another refill.":{"msgid":"You have an upcoming visit with your provider. Please wait until after it before requesting another refill.","msgstr":["Tienes una próxima visita con tu profesional de la salud. Por favor, espera hasta después de la cita antes de solicitar otro resurtido."]},"Your subscriptions":{"msgid":"Your subscriptions","msgstr":["Tus suscripciones"]},"Plan":{"msgid":"Plan","msgstr":["Plan"]},"Payment":{"msgid":"Payment","msgstr":["Pago"]},"change to a ${ subscriptionType } ${ wlNexPeriodProduct.name } subscription":{"msgid":"change to a ${ subscriptionType } ${ wlNexPeriodProduct.name } subscription","msgstr":["cambiar a una suscripción ${ subscriptionType } ${ wlNexPeriodProduct.name }"]},"Change":{"msgid":"Change","msgstr":["Cambiar"]},"All set!":{"msgid":"All set!","msgstr":["¡Todo listo!"]},"Gender successfully updated!":{"msgid":"Gender successfully updated!","msgstr":["¡Género actualizado con éxito!"]},"Something is missing...":{"msgid":"Something is missing...","msgstr":["Falta algo..."]}," Before we get started, we just need one quick detail. Please select your sex at birth to help us personalize your experience.":{"msgid":" Before we get started, we just need one quick detail. Please select your sex at birth to help us personalize your experience.","msgstr":[" Antes de comenzar, solo necesitamos un detalle rápido. Por favor, selecciona tu sexo asignado al nacer para ayudarnos a personalizar tu experiencia."]},"Save to profile":{"msgid":"Save to profile","msgstr":["Guardar en el perfil"]},"You\'re currently on a ${ activeWLSubscription.currentProduct.name } subscription for $${ activeWLSubscription.currentProduct.price.price }/${ periodDuration }. Since you were recently prescribed Branded medication, you might want to switch to a subscription that matches your current needs.":{"msgid":"You\'re currently on a ${ activeWLSubscription.currentProduct.name } subscription for $${ activeWLSubscription.currentProduct.price.price }/${ periodDuration }. Since you were recently prescribed Branded medication, you might want to switch to a subscription that matches your current needs.","msgstr":["Actualmente tienes una suscripción a ${ activeWLSubscription.currentProduct.name } por $${ activeWLSubscription.currentProduct.price.price }/${ periodDuration }. Como te han recetado recientemente un medicamento de marca, quizás quieras cambiar a una suscripción que se adapte mejor a tus necesidades actuales."]},"You haven\'t had any payment yet":{"msgid":"You haven\'t had any payment yet","msgstr":["Aún no has realizado ningún pago."]},"Log out":{"msgid":"Log out","msgstr":["Cerrar sesión"]},"Prior consultation with provider required":{"msgid":"Prior consultation with provider required","msgstr":["Se requiere consulta previa con el profesional de la salud"]},"Contact Customer support":{"msgid":"Contact Customer support","msgstr":["Contactar con soporte al cliente"]},"Amount reflects the total after applied coupons":{"msgid":"Amount reflects the total after applied coupons","msgstr":["El monto refleja el total después de aplicar los cupones"]},"Please enter a whole number":{"msgid":"Please enter a whole number","msgstr":["Por favor, ingresa un número entero"]},"Payment failed!":{"msgid":"Payment failed!","msgstr":["¡Pago fallido!"]},"Oops! Your subscription is on pause":{"msgid":"Oops! Your subscription is on pause","msgstr":["¡Ups! Tu suscripción está en pausa"]},"Looks like you\'ve canceled your subscription, so your account is on hold for now. You won\'t receive any medication or be charged until you reactivate it.":{"msgid":"Looks like you\'ve canceled your subscription, so your account is on hold for now. You won\'t receive any medication or be charged until you reactivate it.","msgstr":["Parece que cancelaste tu suscripción, así que tu cuenta está en pausa por ahora. No recibirás medicamentos ni se te cobrará hasta que la reactives."]},"There was an issue with some of your subscription payments":{"msgid":"There was an issue with some of your subscription payments","msgstr":["Hubo un problema con algunos de tus pagos de suscripción"]},"You can still use your active subscriptions, but you won\'t receive medication or be charged for the affected ones until the issue is resolved.":{"msgid":"You can still use your active subscriptions, but you won\'t receive medication or be charged for the affected ones until the issue is resolved.","msgstr":["Aún puedes usar tus suscripciones activas, pero no recibirás medicamentos ni se te cobrará por las afectadas hasta que se resuelva el problema."]},"Update":{"msgid":"Update","msgstr":["Actualizar"]},"You haven\'t added a payment method yet.":{"msgid":"You haven\'t added a payment method yet.","msgstr":["Aún no has agregado un método de pago."]},"Hair growth":{"msgid":"Hair growth","msgstr":["Crecimiento capilar"]},"Failed":{"msgid":"Failed","msgstr":["Fallido"]},"Processing":{"msgid":"Processing","msgstr":["Procesando"]},"Completed":{"msgid":"Completed","msgstr":["Completado"]},"Schedule now":{"msgid":"Schedule now","msgstr":["Agende ahora"]},"Video visit required":{"msgid":"Video visit required","msgstr":["Se requiere visita por video"]},"Confirm":{"msgid":"Confirm","msgstr":["Confirmar"]},"Check-in":{"msgid":"Check-in","msgstr":["Registro"]},"How is Microdosing working out for you?":{"msgid":"How is Microdosing working out for you?","msgstr":["¿Cómo te está funcionando Microdosing?"]},"We hope everything is going smoothly! If you\'ve had any issues, please\\ncomplete the intake form so we can better support you.":{"msgid":"We hope everything is going smoothly! If you\'ve had any issues, please\\ncomplete the intake form so we can better support you.","msgstr":["¡Esperamos que todo esté yendo bien! Si has tenido algún problema, por favor\\ncompleta el formulario de admisión para que podamos apoyarte mejor."]},"Go to form":{"msgid":"Go to form","msgstr":["Ir al formulario"]},"All good":{"msgid":"All good","msgstr":["Todo bien"]},"Confirm cancellation":{"msgid":"Confirm cancellation","msgstr":["Confirmar cancelación"]},"Cancel subscription":{"msgid":"Cancel subscription","msgstr":["Cancelar suscripción"]},"Subscription discount successfully applied!":{"msgid":"Subscription discount successfully applied!","msgstr":["¡Descuento de suscripción aplicado con éxito!"]},"We\'d love for you to stay!":{"msgid":"We\'d love for you to stay!","msgstr":["¡Nos encantaría que te quedaras!"]},"We\'re offering you a special deal to explore Fridays to its full potential. If you have questions or need support, our team is here to help!":{"msgid":"We\'re offering you a special deal to explore Fridays to its full potential. If you have questions or need support, our team is here to help!","msgstr":["Te estamos ofreciendo una oferta especial para explorar Fridays a su máximo potencial. Si tienes preguntas o necesitas apoyo, ¡nuestro equipo está aquí para ayudarte!"]},"$${ discount.credit.value } off your next billing cycle!":{"msgid":"$${ discount.credit.value } off your next billing cycle!","msgstr":["¡$${ discount.credit.value } de descuento en tu próximo ciclo de facturación!"]},"Yes, I\'m in!":{"msgid":"Yes, I\'m in!","msgstr":["¡Sí, lo quiero!"]},"No, thanks":{"msgid":"No, thanks","msgstr":["No, gracias"]},"We\'ll miss you at Fridays!":{"msgid":"We\'ll miss you at Fridays!","msgstr":["¡Te extrañaremos en Fridays!"]},"Your Fridays subscription will change on ${ endDate }. You can continue using the platform until then and reactivate your subscription anytime from the Billing tab.":{"msgid":"Your Fridays subscription will change on ${ endDate }. You can continue using the platform until then and reactivate your subscription anytime from the Billing tab.","msgstr":["Tu suscripción a Fridays cambiará el ${ endDate }. Puedes continuar usando la plataforma hasta entonces y reactivar tu suscripción en cualquier momento desde la pestaña de Facturación."]},"Can we do better?":{"msgid":"Can we do better?","msgstr":["¿Podemos mejorar?"]},"Before you cancel your subscription, we want to understand what led to your decision. Please select all that apply.":{"msgid":"Before you cancel your subscription, we want to understand what led to your decision. Please select all that apply.","msgstr":["Antes de que canceles tu suscripción, queremos entender qué te llevó a tomar esa decisión. Por favor, selecciona todas las opciones que apliquen."]},"Active until ${ cancelDate }":{"msgid":"Active until ${ cancelDate }","msgstr":["Activa hasta ${ cancelDate }"]},"mo":{"msgid":"mo","msgstr":["mes"]},"Available times${ availability }":{"msgid":"Available times${ availability }","msgstr":["Horarios disponibles${ availability }"]},"Choose an available day":{"msgid":"Choose an available day","msgstr":["Elige un día disponible"]},"Rescheduling successful!":{"msgid":"Rescheduling successful!","msgstr":["¡Reprogramación exitosa!"]},"Journey support consultation":{"msgid":"Journey support consultation","msgstr":["Consulta de apoyo"]},"Reschedule appointment":{"msgid":"Reschedule appointment","msgstr":["Reprogramar cita"]},"Group coaching":{"msgid":"Group coaching","msgstr":["Sesiones grupales"]},"1-on-1 support":{"msgid":"1-on-1 support","msgstr":["Acompañamiento individual"]},"See all":{"msgid":"See all","msgstr":["Ver todo"]},"Coach preference":{"msgid":"Coach preference","msgstr":["Preferencia de coach"]},"No past sessions yet":{"msgid":"No past sessions yet","msgstr":["Aún no tienes sesiones pasadas"]},"Type":{"msgid":"Type","msgstr":["Tipo"]},"Journey support":{"msgid":"Journey support","msgstr":["Apoyo"]},"Past appointments":{"msgid":"Past appointments","msgstr":["Citas anteriores"]},"Book 1-on-1":{"msgid":"Book 1-on-1","msgstr":["Reservar 1 a 1"]},"Dietitian visit":{"msgid":"Dietitian visit","msgstr":["Consulta con nutricionista"]},"Book a 1:1 journey support coaching session":{"msgid":"Book a 1:1 journey support coaching session","msgstr":["Reserva una sesión de apoyo 1 a 1"]},"Session already booked. Check it out in your agenda.":{"msgid":"Session already booked. Check it out in your agenda.","msgstr":["Sesión ya reservada. Revísala en tu agenda."]},"Book your 1:1 nutritional counseling session!":{"msgid":"Book your 1:1 nutritional counseling session!","msgstr":["¡Reserva tu sesión de consejería nutricional 1 a 1!"]},"By continuing, you agree that you have read and understand the nutritional ${ counselingLink }.":{"msgid":"By continuing, you agree that you have read and understand the nutritional ${ counselingLink }.","msgstr":["Al continuar, confirmas que has leído y comprendido la ${ counselingLink } nutricional."]},"Unsubscribe from this session?":{"msgid":"Unsubscribe from this session?","msgstr":["¿Darte de baja de esta sesión?"]},"By clicking the \\"Unsubscribe\\" button, you are missing your place for this session.":{"msgid":"By clicking the \\"Unsubscribe\\" button, you are missing your place for this session.","msgstr":["Al hacer clic en el botón \\"Darse de baja\\", perderás tu lugar en esta sesión."]},"Unsubscribe":{"msgid":"Unsubscribe","msgstr":["Darse de baja"]},"Reschedule":{"msgid":"Reschedule","msgstr":["Reprogramar"]},"Oops, it looks like something went wrong":{"msgid":"Oops, it looks like something went wrong","msgstr":["Ups, parece que algo salió mal"]},"Please try again, or reach out to support if the issue continues.":{"msgid":"Please try again, or reach out to support if the issue continues.","msgstr":["Por favor, intenta nuevamente o contacta al soporte si el problema persiste."]},"Are you sure you want to cancel?":{"msgid":"Are you sure you want to cancel?","msgstr":["¿Estás seguro de que deseas cancelar?"]},"Canceling your appointment with will mean losing your spot. However, you can always book a new one at a time that works for you.":{"msgid":"Canceling your appointment with will mean losing your spot. However, you can always book a new one at a time that works for you.","msgstr":["Cancelar tu cita significará perder tu lugar. Sin embargo, siempre puedes reservar una nueva en el horario que prefieras."]},"No, keep consultation":{"msgid":"No, keep consultation","msgstr":["No, mantener la consulta"]},"Yes, cancel":{"msgid":"Yes, cancel","msgstr":["Sí, cancelar"]},"Need to reschedule?":{"msgid":"Need to reschedule?","msgstr":["¿Necesitas reprogramar?"]},"Cancel and rebook":{"msgid":"Cancel and rebook","msgstr":["Cancelar y reservar de nuevo"]},"A video visit with a provider is required before your next refill can be processed.":{"msgid":"A video visit with a provider is required before your next refill can be processed.","msgstr":["Se requiere una consulta por video con un profesional de la salud antes de poder procesar tu próxima recarga."]},"Upcoming video consultations":{"msgid":"Upcoming video consultations","msgstr":["Próximas videoconsultas"]},"You\'ll receive your referral credit once the person you referred has been an active Fridays member for 30 days.":{"msgid":"You\'ll receive your referral credit once the person you referred has been an active Fridays member for 30 days.","msgstr":["Recibirás tu crédito de referencia una vez que la persona a la que refieres haya sido un miembro activo de Fridays durante 30 días."]},"Sharing a referral code does not make you an affiliate or representative of Fridays Health.":{"msgid":"Sharing a referral code does not make you an affiliate or representative of Fridays Health.","msgstr":["Compartir un código de referencia no te convierte en un afiliado o representante de Fridays Health."]},"You can apply up to $${ REFERRAL_MONTHLY_CAP_CREDIT } in credit monthly.":{"msgid":"You can apply up to $${ REFERRAL_MONTHLY_CAP_CREDIT } in credit monthly.","msgstr":["Puedes aplicar hasta $${ REFERRAL_MONTHLY_CAP_CREDIT } en créditos mensualmente."]},"Additional terms":{"msgid":"Additional terms","msgstr":["Términos adicionales"]},"How does it work?":{"msgid":"How does it work?","msgstr":["¿Cómo funciona?"]},"This modal explains how the referral program works, showing the steps to share a code.":{"msgid":"This modal explains how the referral program works, showing the steps to share a code.","msgstr":["Este modal explica cómo funciona el programa de referencias, mostrando los pasos para compartir un código."]},"Share your unique referral code with friends and family.":{"msgid":"Share your unique referral code with friends and family.","msgstr":["Comparte tu código de referencia único con amigos y familiares."]},"They use the code when they sign up.":{"msgid":"They use the code when they sign up.","msgstr":["Ellos usan el código cuando se inscriben."]},"They get $${ REFERRAL_GIVE_CREDIT_AMOUNT } off their first month and you get $${ REFERRAL_RECEIVE_CREDIT_AMOUNT } in Fridays account credit!":{"msgid":"They get $${ REFERRAL_GIVE_CREDIT_AMOUNT } off their first month and you get $${ REFERRAL_RECEIVE_CREDIT_AMOUNT } in Fridays account credit!","msgstr":["Ellos obtienen $${ REFERRAL_GIVE_CREDIT_AMOUNT } de descuento en su primer mes y tú recibes $${ REFERRAL_RECEIVE_CREDIT_AMOUNT } en crédito en tu cuenta de Fridays!"]},"Referral dashboard":{"msgid":"Referral dashboard","msgstr":["Panel de referidos"]},"Referral program":{"msgid":"Referral program","msgstr":["Programa de referidos"]},"Check your dashboard":{"msgid":"Check your dashboard","msgstr":["Revisa tu panel"]},"Code copied to clipboard.":{"msgid":"Code copied to clipboard.","msgstr":["Código copiado al portapapeles."]},"Your unique referral code":{"msgid":"Your unique referral code","msgstr":["Tu código único de referido"]},"See how it works":{"msgid":"See how it works","msgstr":["Mira cómo funciona"]},"Referral summary":{"msgid":"Referral summary","msgstr":["Resumen de referidos"]},"Coupon applied! Your discount has been added.":{"msgid":"Coupon applied! Your discount has been added.","msgstr":["¡Cupón aplicado! Tu descuento ha sido agregado."]},"You\'re almost there!":{"msgid":"You\'re almost there!","msgstr":["¡Ya casi lo logras!"]},"To get started with Fridays, you\'ll need a quick video visit with one of our medical providers. This helps us personalize your care and ensure it\'s safe to begin your medication.":{"msgid":"To get started with Fridays, you\'ll need a quick video visit with one of our medical providers. This helps us personalize your care and ensure it\'s safe to begin your medication.","msgstr":["Para comenzar con Fridays, necesitarás una breve video consulta con uno de nuestros profesionales de la salud. Esto nos ayuda a personalizar tu atención y garantizar que sea seguro comenzar tu medicación."]},"Confirm consultation":{"msgid":"Confirm consultation","msgstr":["Confirmar consulta"]},"support":{"msgid":"support","msgstr":["soporte"]},"Mark as received":{"msgid":"Mark as received","msgstr":["Marcar como recibido"]},"Great! Your medication was marked as received.":{"msgid":"Great! Your medication was marked as received.","msgstr":["¡Genial! Tu medicamento fue marcado como recibido."]},"What\'s the purpose of your consultation?":{"msgid":"What\'s the purpose of your consultation?","msgstr":["¿Cuál es el propósito de tu consulta?"]},"Please choose the option that best matches your reason for reaching out today to help us provide the best support possible.":{"msgid":"Please choose the option that best matches your reason for reaching out today to help us provide the best support possible.","msgstr":["Por favor, elige la opción que mejor coincida con la razón por la que te contactas hoy para ayudarnos a brindarte el mejor apoyo posible."]},"Past consultations":{"msgid":"Past consultations","msgstr":["Consultas pasadas"]},"Reschedule consultation":{"msgid":"Reschedule consultation","msgstr":["Reprogramar consulta"]},"Upcoming consultations":{"msgid":"Upcoming consultations","msgstr":["Próximas consultas"]},"You won\'t be able to request medication until your current request has been delivered.":{"msgid":"You won\'t be able to request medication until your current request has been delivered.","msgstr":["No podrás solicitar medicación hasta que se haya entregado tu solicitud actual."]},"You can reschedule your appointment up to 7 days after the original date — no need to fill out the intake form again.":{"msgid":"You can reschedule your appointment up to 7 days after the original date — no need to fill out the intake form again.","msgstr":["Puedes reprogramar tu cita hasta 7 días después de la fecha original, no es necesario completar nuevamente el formulario inicial."]},"If you need a later date, please cancel and rebook a new consultation.":{"msgid":"If you need a later date, please cancel and rebook a new consultation.","msgstr":["Si necesitas una fecha posterior, por favor cancela y agenda una nueva consulta."]},"more than 12 days":{"msgid":"more than 12 days","msgstr":["más de 12 días"]},"We\'ll mark this medication as received and update your order status.":{"msgid":"We\'ll mark this medication as received and update your order status.","msgstr":["Marcaremos este medicamento como recibido y actualizaremos el estado de tu pedido."]},"Yes, I\'ve received it":{"msgid":"Yes, I\'ve received it","msgstr":["Si, lo he recibido"]},"Longevity":{"msgid":"Longevity","msgstr":["Longevidad"]},"If it\'s been ${ daysStrong } since you placed your order and you haven\'t received it yet, please reach out to ${ supportButton }. If you\'re still within that timeframe, just hit ${ backStrong }.":{"msgid":"If it\'s been ${ daysStrong } since you placed your order and you haven\'t received it yet, please reach out to ${ supportButton }. If you\'re still within that timeframe, just hit ${ backStrong }.","msgstr":["Si han pasado ${ daysStrong } desde que realizaste tu pedido y aún no lo recibiste, por favor contacta a ${ supportButton }. Si todavía estás dentro de ese plazo, simplemente haz clic en ${ backStrong }."]},"Dietitian form questions":{"msgid":"Dietitian form questions","msgstr":["Preguntas del formulario del dietista"]},"Schedule":{"msgid":"Schedule","msgstr":["Agendar"]},"Reschedule dietitian visit":{"msgid":"Reschedule dietitian visit","msgstr":["Reprogramar visita con dietista"]},"Shop":{"msgid":"Shop","msgstr":["Tienda"]},"intake form":{"msgid":"intake form","msgstr":["formulario de admisión"]},"Go to Home":{"msgid":"Go to Home","msgstr":["Ir al Inicio"]},"Go to intake":{"msgid":"Go to intake","msgstr":["Ir al formulario"]},"All":{"msgid":"All","msgstr":["Todos"]},"Product details for ${ product.name }.":{"msgid":"Product details for ${ product.name }.","msgstr":["Detalles del producto ${ product.name }"]},"Clicking \\"Select\\" will take you to the summary page to review your selection.":{"msgid":"Clicking \\"Select\\" will take you to the summary page to review your selection.","msgstr":["Al hacer clic en \\"Seleccionar\\" vas a ser dirigido a la página de resumen para revisar tu elección."]},"We are processing your payment!":{"msgid":"We are processing your payment!","msgstr":["¡Estamos procesando tu pago!"]},"Ineligible":{"msgid":"Ineligible","msgstr":["No elegible"]},"Current category":{"msgid":"Current category","msgstr":["Categoría actual"]},"Current product variant":{"msgid":"Current product variant","msgstr":["Variante actual del producto"]},"Learn more":{"msgid":"Learn more","msgstr":["Ver más"]},"Important information":{"msgid":"Important information","msgstr":["Información importante"]},"Common disqualifiers":{"msgid":"Common disqualifiers","msgstr":["Factores comunes de descalificación"]},"Select":{"msgid":"Select","msgstr":["Seleccionar"]},"Messages":{"msgid":"Messages","msgstr":["Mensajes"]},"Hmm, something\'s not right":{"msgid":"Hmm, something\'s not right","msgstr":["Hmm, algo no está bien"]},"We\'re having trouble loading products right now. Try refreshing the page or check back soon!":{"msgid":"We\'re having trouble loading products right now. Try refreshing the page or check back soon!","msgstr":["Estamos teniendo problemas para cargar los productos. Prueba recargar la página o vuelve a intentarlo más tarde."]},"Looks like there are no products available.":{"msgid":"Looks like there are no products available.","msgstr":["Parece que no hay productos disponibles."]},"Profile":{"msgid":"Profile","msgstr":["Perfil"]},"Help":{"msgid":"Help","msgstr":["Ayuda"]},"Let\'s meet":{"msgid":"Let\'s meet","msgstr":["Conozcámonos"]},"Monthly":{"msgid":"Monthly","msgstr":["Mensual"]},"Quarterly":{"msgid":"Quarterly","msgstr":["Trimestral"]},"Semi-annually":{"msgid":"Semi-annually","msgstr":["Semestral"]},"Annually":{"msgid":"Annually","msgstr":["Anual"]},"Credit can be applied to upcoming subscription charges.":{"msgid":"Credit can be applied to upcoming subscription charges.","msgstr":["El crédito puede aplicarse a los próximos cobros de suscripción."]},"Pending credit":{"msgid":"Pending credit","msgstr":["Crédito pendiente"]},"Available credit":{"msgid":"Available credit","msgstr":["Crédito disponible"]},"Discounts cannot be transferred or redeemed for cash value. Credit expires once you leave the Fridays program.":{"msgid":"Discounts cannot be transferred or redeemed for cash value. Credit expires once you leave the Fridays program.","msgstr":["Los descuentos no pueden transferirse ni canjearse por dinero en efectivo. El crédito expira una vez que abandones el programa Fridays."]},"Credit applies to all subscription fees.":{"msgid":"Credit applies to all subscription fees.","msgstr":["El crédito aplica a todas las tarifas de suscripción."]},"Product unavailable":{"msgid":"Product unavailable","msgstr":["Producto no disponible"]},"Not available":{"msgid":"Not available","msgstr":["No disponible"]},"Credit amount successfully applied!":{"msgid":"Credit amount successfully applied!","msgstr":["¡Monto de crédito aplicado con éxito!"]},"Share":{"msgid":"Share","msgstr":["Compartir"]},"Select amount to apply to next purchase":{"msgid":"Select amount to apply to next purchase","msgstr":["Selecciona el monto a aplicar en la próxima compra"]},"credit":{"msgid":"credit","msgstr":["crédito"]},"You\'ll need $${ REFERRAL_MINIMUM_CREDIT_AMOUNT } in credit to unlock savings. Invite friends and start earning today!":{"msgid":"You\'ll need $${ REFERRAL_MINIMUM_CREDIT_AMOUNT } in credit to unlock savings. Invite friends and start earning today!","msgstr":["Necesitas $${ REFERRAL_MINIMUM_CREDIT_AMOUNT } en crédito para desbloquear ahorros. ¡Invita amigos y comienza a ganar hoy!"]},"$${ credit.queued } off of your next invoice from referral credit":{"msgid":"$${ credit.queued } off of your next invoice from referral credit","msgstr":["$${ credit.queued } de descuento en tu próxima factura por crédito de referido"]},"Credit earned, available after your referral has been an active member for 30 days.":{"msgid":"Credit earned, available after your referral has been an active member for 30 days.","msgstr":["Crédito ganado, disponible después de que tu referido haya sido miembro activo durante 30 días."]},"Credit ready to manually apply to your next invoice or store purchase.":{"msgid":"Credit ready to manually apply to your next invoice or store purchase.","msgstr":["Crédito listo para aplicar manualmente en tu próxima factura o compra en la tienda."]},"Share code":{"msgid":"Share code","msgstr":["Compartir código"]},"You\'ve already used your $${ REFERRAL_MONTHLY_CAP_CREDIT } monthly credit":{"msgid":"You\'ve already used your $${ REFERRAL_MONTHLY_CAP_CREDIT } monthly credit","msgstr":["Ya has utilizado tu crédito mensual de $${ REFERRAL_MONTHLY_CAP_CREDIT }"]},"Refer friends to earn credit and unlock savings! Check it out ${ hereButton }.":{"msgid":"Refer friends to earn credit and unlock savings! Check it out ${ hereButton }.","msgstr":["¡Refiere amigos para ganar crédito y desbloquear ahorros! Descúbrelo ${ hereButton }."]},"Subtotal":{"msgid":"Subtotal","msgstr":["Subtotal"]},"You may still be a great fit":{"msgid":"You may still be a great fit","msgstr":["Podrías ser una gran opción todavía"]},"While this treatment may not be right for you right now, we have other powerful options to support your health goals.":{"msgid":"While this treatment may not be right for you right now, we have other powerful options to support your health goals.","msgstr":["Aunque este tratamiento puede que no sea adecuado para ti en este momento, tenemos otras poderosas opciones para apoyar tus objetivos de salud."]},"If you\'re looking to boost your energy, sharpen your mind, and feel your best, check out our Longevity program - it might be exactly what you need next.":{"msgid":"If you\'re looking to boost your energy, sharpen your mind, and feel your best, check out our Longevity program - it might be exactly what you need next.","msgstr":["Si buscas aumentar tu energía, agudizar tu mente y sentirte al máximo, revisa nuestro programa de Longevidad: podría ser exactamente lo que necesitas a continuación."]},"Explore Longevity":{"msgid":"Explore Longevity","msgstr":["Explora Longevidad"]},"Join me on Fridays":{"msgid":"Join me on Fridays","msgstr":["Únete a Fridays"]},"Sharing failed, please try again":{"msgid":"Sharing failed, please try again","msgstr":["No se pudo compartir, por favor intenta de nuevo"]},"Height (cm)":{"msgid":"Height (cm)","msgstr":["Altura (cm)"]},"E.g. 160":{"msgid":"E.g. 160","msgstr":["Ej. 160"]},"Weight (kg)":{"msgid":"Weight (kg)","msgstr":["Peso (kg)"]},"Unit system":{"msgid":"Unit system","msgstr":["Sistema de unidades"]},"Your BMI Score is ${ bmi }":{"msgid":"Your BMI Score is ${ bmi }","msgstr":["Tu puntaje de IMC es ${ bmi }"]},"Unable to create consultation":{"msgid":"Unable to create consultation","msgstr":["No se pudo crear la consulta"]},"We couldn\'t complete your consultation due to a system error. Please try again shortly.":{"msgid":"We couldn\'t complete your consultation due to a system error. Please try again shortly.","msgstr":["No pudimos completar tu consulta debido a un error del sistema. Por favor, intenta nuevamente en breve."]},"You can view the details in the Home or Consultations section.":{"msgid":"You can view the details in the Home or Consultations section.","msgstr":["Puedes ver los detalles en la sección Inicio o Consultas."]},"Chosen date: ":{"msgid":"Chosen date: ","msgstr":["Fecha elegida: "]},"Chosen time: ":{"msgid":"Chosen time: ","msgstr":["Hora elegida: "]},"Provider: ":{"msgid":"Provider: ","msgstr":["Profesional: "]},"Use my code ${ referralCode } to get $${ REFERRAL_GIVE_CREDIT_AMOUNT } and start your wellness journey.":{"msgid":"Use my code ${ referralCode } to get $${ REFERRAL_GIVE_CREDIT_AMOUNT } and start your wellness journey.","msgstr":["Usa mi código ${ referralCode } y recibe $${ REFERRAL_GIVE_CREDIT_AMOUNT } y da el primer paso hacia tu bienestar."]},"You already have a scheduled consultation for this purpose":{"msgid":"You already have a scheduled consultation for this purpose","msgstr":["Ya tienes una consulta programada para este propósito"]},"You already have a medication request for this purpose":{"msgid":"You already have a medication request for this purpose","msgstr":["Ya tienes una solicitud de medicación para este propósito"]},"Call us":{"msgid":"Call us","msgstr":["Llámanos"]},"Meal Delivery":{"msgid":"Meal Delivery","msgstr":["Entrega de comidas"]},"Got it!":{"msgid":"Got it!","msgstr":["Entendido!"]},"Name is required":{"msgid":"Name is required","msgstr":["Nombre requerido"]},"Invalid journey":{"msgid":"Invalid journey","msgstr":["Valor seleccionado inválido"]},"Not currently available in your state":{"msgid":"Not currently available in your state","msgstr":["Actualmente no disponible en tu estado"]},"Phone number must contain only 10 numbers":{"msgid":"Phone number must contain only 10 numbers","msgstr":["El número de teléfono debe contener solo 10 dígitos"]},"Telehealth Consent 1":{"msgid":"Telehealth Consent 1","msgstr":["Consentimiento de Telemedicina 1"]},"Telehealth Consent 2":{"msgid":"Telehealth Consent 2","msgstr":["Consentimiento de Telemedicina 2"]},"E.g. 1234567890":{"msgid":"E.g. 1234567890","msgstr":["Ej. 1234567890"]},"This modal lets you update the name of the document.":{"msgid":"This modal lets you update the name of the document.","msgstr":["Este modal te permite actualizar el nombre del documento."]},"This modal lets you remove the document.":{"msgid":"This modal lets you remove the document.","msgstr":["Este modal te permite eliminar el documento."]},"Update the details for your preferred payment method.":{"msgid":"Update the details for your preferred payment method.","msgstr":["Actualiza los detalles de tu método de pago preferido."]},"Dietitian":{"msgid":"Dietitian","msgstr":["Nutricionista"]},"Professional":{"msgid":"Professional","msgstr":["Profesional"]},"Submission successful!":{"msgid":"Submission successful!","msgstr":["¡Envío exitoso!"]},"months":{"msgid":"months","msgstr":["meses"]},"Why are you cancelling?":{"msgid":"Why are you cancelling?","msgstr":["¿Por qué estás cancelando?"]},"Date of birth successfully updated!":{"msgid":"Date of birth successfully updated!","msgstr":["¡Fecha de nacimiento actualizada con éxito!"]},"Before we get started, we just need one quick detail. Please complete your date of birth to help us personalize your experience.":{"msgid":"Before we get started, we just need one quick detail. Please complete your date of birth to help us personalize your experience.","msgstr":["Antes de comenzar, solo necesitamos un detalle rápido. Por favor completa tu fecha de nacimiento para ayudarnos a personalizar tu experiencia."]},"No worries — our technical team has been notified and will be in touch with a solution. Thanks for your patience!":{"msgid":"No worries — our technical team has been notified and will be in touch with a solution. Thanks for your patience!","msgstr":["No te preocupes, nuestro equipo técnico ha sido notificado y se pondrá en contacto contigo con una solución. ¡Gracias por tu paciencia!"]},"Subscription canceled":{"msgid":"Subscription canceled","msgstr":["Suscripción cancelada"]},"Your ${ subscription.currentProduct.name } subscription will end on ${ endDate }. Don\'t worry—you still have other active subscriptions, so you\'ll continue enjoying Fridays without interruption.":{"msgid":"Your ${ subscription.currentProduct.name } subscription will end on ${ endDate }. Don\'t worry—you still have other active subscriptions, so you\'ll continue enjoying Fridays without interruption.","msgstr":["Tu suscripción a ${ subscription.currentProduct.name } finalizará el ${ endDate }. No te preocupes; aún tienes otras suscripciones activas, así que continuarás disfrutando de Fridays sin interrupciones."]},"Atlantic Time":{"msgid":"Atlantic Time","msgstr":["Hora Atlántica"]},"Request made on ${ medicationRequest.dateOfRequest }":{"msgid":"Request made on ${ medicationRequest.dateOfRequest }","msgstr":["Solicitud realizada el ${ medicationRequest.dateOfRequest }"]},"Consultation purpose":{"msgid":"Consultation purpose","msgstr":["Propósito de consulta"]},"End date":{"msgid":"End date","msgstr":["Fecha de finalización"]},"Select an end date":{"msgid":"Select an end date","msgstr":["Selecciona una fecha de finalización"]},"Frequency is required":{"msgid":"Frequency is required","msgstr":["La frecuencia es obligatoria"]},"End date is required for recurring sessions":{"msgid":"End date is required for recurring sessions","msgstr":["La fecha de finalización es obligatoria para las sesiones recurrentes"]},"One-time":{"msgid":"One-time","msgstr":["Una sola vez"]},"Weekly":{"msgid":"Weekly","msgstr":["Semanal"]},"Bi-weekly":{"msgid":"Bi-weekly","msgstr":["Cada dos semanas"]},"Frequency":{"msgid":"Frequency","msgstr":["Frecuencia"]},"users":{"msgid":"users","msgstr":["usuarios"]},"enrolled users":{"msgid":"enrolled users","msgstr":["usuarios inscritos"]},"upcoming":{"msgid":"upcoming","msgstr":["próximas"]},"draft":{"msgid":"draft","msgstr":["borrador"]},"past":{"msgid":"past","msgstr":["pasadas"]},"ongoing":{"msgid":"ongoing","msgstr":["en curso"]},"There are no ${ statusLabel } ${ categoryLabel } sessions yet":{"msgid":"There are no ${ statusLabel } ${ categoryLabel } sessions yet","msgstr":["Aún no hay sesiones ${ statusLabel } de ${ categoryLabel }"]},"There are no ${ statusLabel } sessions yet":{"msgid":"There are no ${ statusLabel } sessions yet","msgstr":["Aún no hay sesiones ${ statusLabel }"]},"More information about ${ label }":{"msgid":"More information about ${ label }","msgstr":["Más información acerca de ${ label }"]},"Current Plan":{"msgid":"Current Plan","msgstr":["Plan actual"]},"New Plan":{"msgid":"New Plan","msgstr":["Nuevo Plan"]},"Please complete the ${ intakeFormStrong } to be able to join video consultations or order medication.":{"msgid":"Please complete the ${ intakeFormStrong } to be able to join video consultations or order medication.","msgstr":["Por favor completa el ${ intakeFormStrong } para poder unirte a las consultas por video o pedir medicación."]},"Testosterone":{"msgid":"Testosterone","msgstr":["Testosterona"]},"Action items":{"msgid":"Action items","msgstr":["Acciones pendientes"]},"Please review these items that require you attention.":{"msgid":"Please review these items that require you attention.","msgstr":["Por favor revisa estos elementos que requieren tu atención."]},"${ categoryName } treatments may not be a fit":{"msgid":"${ categoryName } treatments may not be a fit","msgstr":["Los tratamientos de ${ categoryName } pueden no ser adecuados"]},"\\"This coaching helped me set realistic goals—and I hit my 10lb milestone two weeks early!\\"":{"msgid":"\\"This coaching helped me set realistic goals—and I hit my 10lb milestone two weeks early!\\"","msgstr":["\\"Este acompañamiento me ayudó a establecer metas realistas ¡y alcancé mi objetivo de 10 libras dos semanas antes!\\""]},"\\"I\'ve done programs before, but this was the first time I felt like someone was really walking with me.\\"":{"msgid":"\\"I\'ve done programs before, but this was the first time I felt like someone was really walking with me.\\"","msgstr":["\\"He hecho programas antes, pero esta fue la primera vez que sentí que alguien realmente me acompañaba.\\""]},"\\"I didn\'t realize how helpful it would be just to talk to someone who gets it. I\'ve stayed more motivated since our first session.\\"":{"msgid":"\\"I didn\'t realize how helpful it would be just to talk to someone who gets it. I\'ve stayed more motivated since our first session.\\"","msgstr":["\\"No me di cuenta de lo útil que sería simplemente hablar con alguien que entiende. He estado más motivado desde nuestra primera sesión.\\""]},"\\"I thought I was plateauing, but my coach helped me make a small tweak that made a big difference.\\"":{"msgid":"\\"I thought I was plateauing, but my coach helped me make a small tweak that made a big difference.\\"","msgstr":["\\"Pensé que estaba estancado, pero mi coach me ayudó a hacer un pequeño ajuste que marcó una gran diferencia.\\""]},"free":{"msgid":"free","msgstr":["gratis"]},"Ready to team up? ":{"msgid":"Ready to team up? ","msgstr":["¿Listo para trabajar en equipo? "]},"Book a session now!":{"msgid":"Book a session now!","msgstr":["¡Reserva una sesión ahora!"]},"need to contact customer support to request a refund for your payment":{"msgid":"need to contact customer support to request a refund for your payment","msgstr":["debes contactar al soporte al cliente para solicitar un reembolso de tu pago"]},"You\'ve been prescribed ${ requestedProduct.name }, but you\'re currently on the ${ currentProduct.name } plan. To receive this medication, you\'ll need to switch your subscription.":{"msgid":"You\'ve been prescribed ${ requestedProduct.name }, but you\'re currently on the ${ currentProduct.name } plan. To receive this medication, you\'ll need to switch your subscription.","msgstr":["Te han recetado ${ requestedProduct.name }, pero actualmente tienes el plan ${ currentProduct.name }. Para recibir este medicamento, deberás cambiar tu suscripción."]},"continue to receive medications according to your current subscription":{"msgid":"continue to receive medications according to your current subscription","msgstr":["continuar recibiendo medicamentos según tu suscripción actual"]},"Approving this change will update your subscription and charge $${ requestedProduct.price.price } to your card on file. If your new subscription is less expensive, a partial refund may be issued. If you don\'t approve, you\'ll ${ declineMessage }. If you need additional help, ${ messagesButton }":{"msgid":"Approving this change will update your subscription and charge $${ requestedProduct.price.price } to your card on file. If your new subscription is less expensive, a partial refund may be issued. If you don\'t approve, you\'ll ${ declineMessage }. If you need additional help, ${ messagesButton }","msgstr":["Aprobar este cambio actualizará tu suscripción y se cobrará $${ requestedProduct.price.price } a tu tarjeta registrada. Si tu nueva suscripción es más económica, se puede emitir un reembolso parcial. Si no apruebas, ${ declineMessage }. Si necesitas ayuda adicional, ${ messagesButton }"]},"Before you schedule":{"msgid":"Before you schedule","msgstr":["Antes de agendar"]},"You\'ll be redirected to our lab partner\'s site to book your appointment. You only need to do this once — after that, just wait for your results. We\'ll notify you when they\'re ready so you can continue with your treatment!":{"msgid":"You\'ll be redirected to our lab partner\'s site to book your appointment. You only need to do this once — after that, just wait for your results. We\'ll notify you when they\'re ready so you can continue with your treatment!","msgstr":["Serás redirigido al sitio de nuestro socio de laboratorio para agendar tu cita. Solo necesitas hacerlo una vez; después de eso, solo espera tus resultados. Te avisaremos cuando estén listos para que puedas continuar con tu tratamiento."]},"Continue to booking":{"msgid":"Continue to booking","msgstr":["Continuar a la reserva"]},"You\'re being redirected":{"msgid":"You\'re being redirected","msgstr":["Estás siendo redirigido"]},"You\'ll be redirected to an external site to complete the next step. You can return here once you\'re finished.":{"msgid":"You\'ll be redirected to an external site to complete the next step. You can return here once you\'re finished.","msgstr":["Serás redirigido a un sitio externo para completar el siguiente paso. Puedes regresar aquí cuando termines."]},"Continue to external site":{"msgid":"Continue to external site","msgstr":["Continuar al sitio externo"]},"Intake form":{"msgid":"Intake form","msgstr":["Formulario de admisión"]},"Biomarkers test":{"msgid":"Biomarkers test","msgstr":["Prueba de biomarcadores"]},"Provider consultation":{"msgid":"Provider consultation","msgstr":["Consulta con el profesional"]},"Get requisition form":{"msgid":"Get requisition form","msgstr":["Obtener formulario de solicitud"]},"Due now":{"msgid":"Due now","msgstr":["Pendiente ahora"]},"TRT Treatment":{"msgid":"TRT Treatment","msgstr":["Tratamiento TRT"]},"Labs are in!":{"msgid":"Labs are in!","msgstr":["¡Tus laboratorios están listos!"]},"Your results are ready. Meet with a provider to review your labs and take the next step in your treatment.":{"msgid":"Your results are ready. Meet with a provider to review your labs and take the next step in your treatment.","msgstr":["Tus resultados están listos. Agenda una consulta con un profesional para revisar tus laboratorios y dar el siguiente paso en tu tratamiento."]},"Schedule consultation":{"msgid":"Schedule consultation","msgstr":["Agendar consulta"]},"You\'ll need updated labs before we can ship your meds. You can schedule them anytime from Home.":{"msgid":"You\'ll need updated labs before we can ship your meds. You can schedule them anytime from Home.","msgstr":["Necesitas laboratorios actualizados antes de que podamos enviar tus medicamentos. Puedes agendarlos en cualquier momento desde Inicio."]},"Form":{"msgid":"Form","msgstr":["Formulario"]},"The order is not ready yet, please try again later or contact support":{"msgid":"The order is not ready yet, please try again later or contact support","msgstr":["La orden aún no está lista, por favor intenta de nuevo más tarde o contacta al soporte"]},"Don\'t approve change":{"msgid":"Don\'t approve change","msgstr":["No aprobar cambio"]},"Approve change":{"msgid":"Approve change","msgstr":["Aprobar cambio"]},"Get refill":{"msgid":"Get refill","msgstr":["Solicitar recarga"]},"You don\'t have an open request.":{"msgid":"You don\'t have an open request.","msgstr":["No tienes una solicitud abierta."]},"Want to repeat?":{"msgid":"Want to repeat?","msgstr":["¿Quieres repetir?"]},"Your product was a one-time purchase.":{"msgid":"Your product was a one-time purchase.","msgstr":["Tu producto fue una compra única."]},"Refills currently unavailable.":{"msgid":"Refills currently unavailable.","msgstr":["Las recargas no están disponibles actualmente."]},"Are you sure you want to decline this change?":{"msgid":"Are you sure you want to decline this change?","msgstr":["¿Estás seguro de que deseas rechazar este cambio?"]},"If you don\'t approve the switch, we won\'t be able to ship your medication for you to start your treatment. We\'ll connect you with Customer Support to cancel your subscription and request a refund.":{"msgid":"If you don\'t approve the switch, we won\'t be able to ship your medication for you to start your treatment. We\'ll connect you with Customer Support to cancel your subscription and request a refund.","msgstr":["Si no apruebas el cambio, no podremos enviar tu medicamento para que inicies tu tratamiento. Te conectaremos con Soporte al Cliente para cancelar tu suscripción y solicitar un reembolso."]},"By rejecting the subscription change requested by your provider, you won\'t receive the medication they believe you need. Are you sure you want to continue?":{"msgid":"By rejecting the subscription change requested by your provider, you won\'t receive the medication they believe you need. Are you sure you want to continue?","msgstr":["Al rechazar el cambio de suscripción solicitado por tu profesional de la salud, no recibirás el medicamento que considera necesario. ¿Estás seguro de que deseas continuar?"]},"We\'ve received your medication request. If anything else is needed, we\'ll let you know. Otherwise, we\'ll start reviewing your request soon!":{"msgid":"We\'ve received your medication request. If anything else is needed, we\'ll let you know. Otherwise, we\'ll start reviewing your request soon!","msgstr":["Hemos recibido tu solicitud de medicación. Si se necesita algo más, te lo haremos saber. De lo contrario, pronto empezaremos a revisar tu solicitud."]},"Enter a valid email":{"msgid":"Enter a valid email","msgstr":["Ingresa un correo válido"]},"Fridays is a great fit for you!":{"msgid":"Fridays is a great fit for you!","msgstr":["¡Fridays es una excelente opción para ti!"]},"We\'re thrilled to be part of your wellness journey. Let\'s make every day feel like a Friday!":{"msgid":"We\'re thrilled to be part of your wellness journey. Let\'s make every day feel like a Friday!","msgstr":["Estamos encantados de ser parte de tu camino hacia el bienestar. ¡Hagamos que cada día se sienta como un viernes!"]},"Congrats! It looks like you\'d be a great candidate for Fridays!":{"msgid":"Congrats! It looks like you\'d be a great candidate for Fridays!","msgstr":["¡Felicidades! ¡Parece que eres un gran candidato para Fridays!"]},"I\'d also like to receive occasional promotions via call and text message. Opt out anytime.":{"msgid":"I\'d also like to receive occasional promotions via call and text message. Opt out anytime.","msgstr":["También me gustaría recibir promociones ocasionales por llamada y mensaje de texto. Puedes darte de baja en cualquier momento."]},"By checking the option \\"I\'d also like to receive occasional promotions via text message. Opt out anytime.\\", I agree to receive marketing text messages from Fridays Health at the number provided above. Messages & calls may use an automatic telephone dialing system. Consent is not required as a condition of purchase. Message and data rates may apply. Message frequency varies. Send HELP for help or STOP to cancel. Messages & calls may include shopping cart reminders.":{"msgid":"By checking the option \\"I\'d also like to receive occasional promotions via text message. Opt out anytime.\\", I agree to receive marketing text messages from Fridays Health at the number provided above. Messages & calls may use an automatic telephone dialing system. Consent is not required as a condition of purchase. Message and data rates may apply. Message frequency varies. Send HELP for help or STOP to cancel. Messages & calls may include shopping cart reminders.","msgstr":["Al seleccionar la opción \\"También me gustaría recibir promociones ocasionales por mensaje de texto. Puedes darte de baja en cualquier momento.\\", acepto recibir mensajes de texto promocionales de Fridays Health al número proporcionado arriba. Los mensajes y llamadas pueden usar un sistema automático de marcación telefónica. El consentimiento no es un requisito para la compra. Pueden aplicarse tarifas de mensajes y datos. La frecuencia de los mensajes varía. Envía HELP para ayuda o STOP para cancelar. Los mensajes y llamadas pueden incluir recordatorios de carrito de compras."]},"We\'ll only use your number to text order updates and important information about your treatments.":{"msgid":"We\'ll only use your number to text order updates and important information about your treatments.","msgstr":["Solo usaremos tu número para enviarte actualizaciones de pedidos e información importante sobre tus tratamientos."]},"Billing address is the same as shipping":{"msgid":"Billing address is the same as shipping","msgstr":["La dirección de facturación es la misma que la de envío"]},"Billing address":{"msgid":"Billing address","msgstr":["Dirección de facturación"]},"Weight (${ WEIGHT_UNIT[unitSystem] }) *":{"msgid":"Weight (${ WEIGHT_UNIT[unitSystem] }) *","msgstr":["Peso (${ WEIGHT_UNIT[unitSystem] }) *"]},"We couldn\'t process your payment. Please check your payment method and try again. If the issue continues, please contact support.":{"msgid":"We couldn\'t process your payment. Please check your payment method and try again. If the issue continues, please contact support.","msgstr":["No pudimos procesar tu pago. Por favor, verifica tu método de pago e intenta nuevamente. Si el problema continúa, contacta a soporte al cliente."]},"Chat with Support":{"msgid":"Chat with Support","msgstr":["Chatear con Soporte"]},"Security":{"msgid":"Security","msgstr":["Seguridad"]},"Biometric Login":{"msgid":"Biometric Login","msgstr":["Inicio de sesión biométrico"]},"Enable Face ID or Fingerprint to log in faster":{"msgid":"Enable Face ID or Fingerprint to log in faster","msgstr":["Activa Face ID o la huella dactilar para iniciar sesión más rápido."]},"These ${ categoryName } treatments might not be the best option for you at the moment — but feel free to keep exploring the other treatments you\'ve selected!":{"msgid":"These ${ categoryName } treatments might not be the best option for you at the moment — but feel free to keep exploring the other treatments you\'ve selected!","msgstr":["Los tratamientos de ${ categoryName } podrían no ser la mejor opción para ti en este momento, pero siéntete libre de seguir explorando los otros tratamientos que has seleccionado."]},"Enter your email":{"msgid":"Enter your email","msgstr":["Ingresa tu correo electrónico"]},"We need to make sure we can support you":{"msgid":"We need to make sure we can support you","msgstr":["Necesitamos asegurarnos de que podamos apoyarte"]},"Choose all that you are interested in":{"msgid":"Choose all that you are interested in","msgstr":["Selecciona todo lo que te interese"]},"Choose your treatment":{"msgid":"Choose your treatment","msgstr":["Elige tu tratamiento"]},"Please select at least one answer to continue":{"msgid":"Please select at least one answer to continue","msgstr":["Por favor, selecciona al menos una respuesta para continuar"]},"Complete your order":{"msgid":"Complete your order","msgstr":["Completa tu pedido"]},"GLP-1 Weight loss":{"msgid":"GLP-1 Weight loss","msgstr":["Pérdida de peso (GLP-1)"]},"GLP-1 Microdosing":{"msgid":"GLP-1 Microdosing","msgstr":["Microdosificación (GLP-1)"]},"Please select at least one plan to continue":{"msgid":"Please select at least one plan to continue","msgstr":["Por favor, selecciona al menos un plan para continuar"]},"We haven’t seen any recent activity on your refill request. Please check which medications you have received, and we’ll request a follow-up for the rest.":{"msgid":"We haven’t seen any recent activity on your refill request. Please check which medications you have received, and we’ll request a follow-up for the rest.","msgstr":["No hemos visto actividad reciente en tu solicitud de recarga. Por favor, verifica qué medicamentos has recibido y solicitaremos un seguimiento para el resto."]},"Any choice below disqualifies you from treatment":{"msgid":"Any choice below disqualifies you from treatment","msgstr":["Cualquier opción a continuación te descalifica del tratamiento"]},"Password Tips":{"msgid":"Password Tips","msgstr":["Consejos de contraseña"]},"Loading options...":{"msgid":"Loading options...","msgstr":["Cargando opciones..."]},"Select an option":{"msgid":"Select an option","msgstr":["Selecciona una opción"]},"Select a state":{"msgid":"Select a state","msgstr":["Selecciona un estado"]},"Missing client secret":{"msgid":"Missing client secret","msgstr":["Falta el secreto del cliente"]},"Something went wrong. Please try again later.":{"msgid":"Something went wrong. Please try again later.","msgstr":["Algo salió mal. Por favor, intenta de nuevo más tarde."]},"Almost there — we\'re redirecting you to Klarna to complete your payment":{"msgid":"Almost there — we\'re redirecting you to Klarna to complete your payment","msgstr":["Casi listo. Te estamos redirigiendo a Klarna para completar tu pago"]},"Credit card":{"msgid":"Credit card","msgstr":["Tarjeta de crédito/débito"]},"Klarna":{"msgid":"Klarna","msgstr":["Klarna"]},"User not found.":{"msgid":"User not found.","msgstr":["Usuario no encontrado."]},"There was a problem creating your subscription. Try again later or contact support.":{"msgid":"There was a problem creating your subscription. Try again later or contact support.","msgstr":["Hubo un problema al crear tu suscripción. Intenta nuevamente más tarde o contacta al soporte."]},"Imperial":{"msgid":"Imperial","msgstr":["Imperial"]},"inches":{"msgid":"inches","msgstr":["pulgadas"]},"Metric":{"msgid":"Metric","msgstr":["Métrico"]},"cm":{"msgid":"cm","msgstr":["cm"]},"Card ending in ${ defaultPaymentMethod.metadata.lastFourDigits }":{"msgid":"Card ending in ${ defaultPaymentMethod.metadata.lastFourDigits }","msgstr":["Tarjeta terminada en ${ defaultPaymentMethod.metadata.lastFourDigits }"]},"Add card":{"msgid":"Add card","msgstr":["Agregar tarjeta"]},"Price information is missing":{"msgid":"Price information is missing","msgstr":["Falta información del precio"]},"Klarna is not available for the selected price":{"msgid":"Klarna is not available for the selected price","msgstr":["Klarna no está disponible para el precio seleccionado"]},"Order summary":{"msgid":"Order summary","msgstr":["Resumen del pedido"]},"Our guarantee: If you pay for a treatment and your provider determines you\'re not eligible, we\'ll issue a full refund":{"msgid":"Our guarantee: If you pay for a treatment and your provider determines you\'re not eligible, we\'ll issue a full refund","msgstr":["Nuestra garantía: si pagas por un tratamiento y tu profesional determina que no eres elegible, emitiremos un reembolso completo"]},"Klarna logo":{"msgid":"Klarna logo","msgstr":["Logo de Klarna"]},"No payment method available. Please add one before proceeding.":{"msgid":"No payment method available. Please add one before proceeding.","msgstr":["No hay ningún método de pago disponible. Por favor añade uno antes de continuar."]},"Remove this item?":{"msgid":"Remove this item?","msgstr":["¿Eliminar este item?"]},"You can add it back before finishing onboarding—or pick it up later in the Shop.":{"msgid":"You can add it back before finishing onboarding—or pick it up later in the Shop.","msgstr":["Puedes volver a añadirlo antes de finalizar el registro o comprarlo más tarde en la Tienda."]},"No, keep item":{"msgid":"No, keep item","msgstr":["No, mantener artículo"]},"Yes, remove":{"msgid":"Yes, remove","msgstr":["Sí, eliminar"]},"There was an issue processing your payment. Please try again using another payment method.":{"msgid":"There was an issue processing your payment. Please try again using another payment method.","msgstr":["Hubo un problema al procesar tu pago. Por favor, inténtalo nuevamente usando otro método de pago."]},"Enrolled users":{"msgid":"Enrolled users","msgstr":["Usuarios inscritos"]},"Name":{"msgid":"Name","msgstr":["Nombre"]},"Emails copied to clipboard":{"msgid":"Emails copied to clipboard","msgstr":["Emails copiados al portapapeles"]},"Copy all emails":{"msgid":"Copy all emails","msgstr":["Copiar todos los emails"]},"An error occurred while processing your payment.":{"msgid":"An error occurred while processing your payment.","msgstr":["Ocurrió un error al procesar tu pago."]},"An error occurred while loading Apple Pay, please select another payment method.":{"msgid":"An error occurred while loading Apple Pay, please select another payment method.","msgstr":["Ocurrió un error al cargar Apple Pay, por favor selecciona otro método de pago."]},"Apple Pay":{"msgid":"Apple Pay","msgstr":["Apple Pay"]},"As seen on":{"msgid":"As seen on","msgstr":["Visto en"]},"If prescribed, where should we ship your order?":{"msgid":"If prescribed, where should we ship your order?","msgstr":["Si es prescrito, ¿a dónde debemos enviar tu pedido?"]},"Find your treatment":{"msgid":"Find your treatment","msgstr":["Encuentra tu tratamiento"]},"Terms & Conditions":{"msgid":"Terms & Conditions","msgstr":["Términos y Condiciones"]},"Enter your details to save your progress":{"msgid":"Enter your details to save your progress","msgstr":["Ingresa tus datos para guardar tu progreso"]},"We\'ll ask a few quick questions to check if treatment is right for you":{"msgid":"We\'ll ask a few quick questions to check if treatment is right for you","msgstr":["Te haremos algunas preguntas rápidas para verificar si el tratamiento es adecuado para ti"]},"You must agree before continuing":{"msgid":"You must agree before continuing","msgstr":["Debes aceptar antes de continuar"]},"Any changes to your subscription will start at the beginning of your next billing cycle. Your current plan stays active until then.":{"msgid":"Any changes to your subscription will start at the beginning of your next billing cycle. Your current plan stays active until then.","msgstr":["Cualquier cambio en tu suscripción comenzará al inicio de tu próximo ciclo de facturación. Tu plan actual permanecerá activo hasta entonces."]},"I agree to the updated pricing and understand the change will begin with my next billing cycle.":{"msgid":"I agree to the updated pricing and understand the change will begin with my next billing cycle.","msgstr":["Acepto los precios actualizados y entiendo que el cambio comenzará con mi próximo ciclo de facturación."]},"Make payment":{"msgid":"Make payment","msgstr":["Realizar pago"]},"Subscription plan successfully upgraded!":{"msgid":"Subscription plan successfully upgraded!","msgstr":["¡Plan de suscripción actualizado con éxito!"]},"Upgrade subscription":{"msgid":"Upgrade subscription","msgstr":["Actualizar suscripción"]},"Upgrade":{"msgid":"Upgrade","msgstr":["Actualizar"]},"Invalid coupon \\"${ checkoutDiscount.code }\\". Please check and try again.":{"msgid":"Invalid coupon \\"${ checkoutDiscount.code }\\". Please check and try again.","msgstr":["Cupón inválido \\"${ checkoutDiscount.code }\\". Por favor verifica e intenta de nuevo."]},"DAYS":{"msgid":"DAYS","msgstr":["DÍAS"]},"HOURS":{"msgid":"HOURS","msgstr":["HORAS"]},"Shop now":{"msgid":"Shop now","msgstr":["Compra ahora"]},"Billing via email invoice":{"msgid":"Billing via email invoice","msgstr":["Se enviará la factura a tu correo electrónico"]},"Description":{"msgid":"Description","msgstr":["Descripción"]},"Write a brief description...":{"msgid":"Write a brief description...","msgstr":["Escribe una breve descripción..."]},"Loading coaches...":{"msgid":"Loading coaches...","msgstr":["Cargando coaches..."]},"Select a coach":{"msgid":"Select a coach","msgstr":["Selecciona un coach"]},"House and street number":{"msgid":"House and street number","msgstr":["Número de casa y calle"]},"Time zone":{"msgid":"Time zone","msgstr":["Zona horaria"]},"I authorize the use of this credit card for my subscription charges.":{"msgid":"I authorize the use of this credit card for my subscription charges.","msgstr":["Autorizo el uso de esta tarjeta de crédito/débito para los cargos de mi suscripción."]},"Please enter a coupon code.":{"msgid":"Please enter a coupon code.","msgstr":["Por favor, ingresa un código de descuento."]},"Booking is unavailable while your request is in progress.":{"msgid":"Booking is unavailable while your request is in progress.","msgstr":["La reserva no está disponible mientras tu solicitud está en progreso."]},"Link expired":{"msgid":"Link expired","msgstr":["Enlace expirado"]},"For your protection, this password setup link has expired.":{"msgid":"For your protection, this password setup link has expired.","msgstr":["Por tu seguridad, este enlace para configurar tu contraseña ha expirado."]},"A new one has been sent to your email - please use it to finish setting up your account.":{"msgid":"A new one has been sent to your email - please use it to finish setting up your account.","msgstr":["Hemos enviado uno nuevo a tu correo electrónico; úsalo para finalizar la configuración de tu cuenta."]},"${ enrolledUsersQuantity } users enrolled in this session":{"msgid":"${ enrolledUsersQuantity } users enrolled in this session","msgstr":["${ enrolledUsersQuantity } usuarios inscriptos en esta sesión"]},"Your payment could not be processed. Please try again with a different payment method.":{"msgid":"Your payment could not be processed. Please try again with a different payment method.","msgstr":["Tu pago no pudo ser procesado. Por favor, intenta de nuevo con un método de pago diferente."]},"Emails must match":{"msgid":"Emails must match","msgstr":["Los correos electrónicos deben coincidir"]},"Confirm email":{"msgid":"Confirm email","msgstr":["Confirmar correo electrónico"]},"Confirm your email":{"msgid":"Confirm your email","msgstr":["Confirma tu correo electrónico"]},"The final step is to complete the intake forms — once you\'re done, you\'ll unlock the full Fridays experience.":{"msgid":"The final step is to complete the intake forms — once you\'re done, you\'ll unlock the full Fridays experience.","msgstr":["El último paso es completar los formularios de admisión. Cuando termines, desbloquearás toda la experiencia Fridays."]},"up to $${ OFFER_DISCOUNT }":{"msgid":"up to $${ OFFER_DISCOUNT }","msgstr":["hasta $${ OFFER_DISCOUNT }"]},"Save ${ discountStrong } on ${ offerNameStrong }":{"msgid":"Save ${ discountStrong } on ${ offerNameStrong }","msgstr":["Ahorra ${ discountStrong } en ${ offerNameStrong }"]},"Please complete your Initial Intake Form before scheduling a Journey Support session.":{"msgid":"Please complete your Initial Intake Form before scheduling a Journey Support session.","msgstr":["Por favor, completá tu formulario de admisión inicial antes de programar una sesión."]},"Personalized support from a Fridays Health Coach to help you set goals, manage challenges and stay on track.":{"msgid":"Personalized support from a Fridays Health Coach to help you set goals, manage challenges and stay on track.","msgstr":["Soporte personalizado de un coach de salud de Fridays para ayudarte a establecer objetivos."]},"Heads up — it might take a few minutes for the update to show.":{"msgid":"Heads up — it might take a few minutes for the update to show.","msgstr":["Aviso - puede tomar algunos minutos para que la actualización se muestre."]},"pending action items":{"msgid":"pending action items","msgstr":["acciones pendientes"]},"You have ${ actionItemsStrong } to complete":{"msgid":"You have ${ actionItemsStrong } to complete","msgstr":["Tienes ${ actionItemsStrong } para completar"]},"Give $${ REFERRAL_GIVE_CREDIT_AMOUNT }, get $${ REFERRAL_RECEIVE_CREDIT_AMOUNT }! Invite friends & family to join Fridays!":{"msgid":"Give $${ REFERRAL_GIVE_CREDIT_AMOUNT }, get $${ REFERRAL_RECEIVE_CREDIT_AMOUNT }! Invite friends & family to join Fridays!","msgstr":["¡Da $${ REFERRAL_GIVE_CREDIT_AMOUNT } y recibe $${ REFERRAL_RECEIVE_CREDIT_AMOUNT }! Invita a tus amigos y familiares a unirse a Fridays."]},"Download later":{"msgid":"Download later","msgstr":["Descargar después"]},"The Fridays app is here":{"msgid":"The Fridays app is here","msgstr":["La app de Fridays ya está aquí"]},"The same care—now made for mobile.":{"msgid":"The same care—now made for mobile.","msgstr":["El mismo cuidado, ahora hecho para móvil."]},"Download for a smoother, faster experience.":{"msgid":"Download for a smoother, faster experience.","msgstr":["Descarga para una experiencia más fluida y rápida."]},"Download on the App Store":{"msgid":"Download on the App Store","msgstr":["Descargar en la App Store"]},"Get it on Google Play":{"msgid":"Get it on Google Play","msgstr":["Consíguelo en Google Play"]},"Don\'t show this again":{"msgid":"Don\'t show this again","msgstr":["No mostrar esto de nuevo"]},"Unknown error":{"msgid":"Unknown error","msgstr":["Error desconocido"]},"You can\'t select both ${ conflictingGlp1Category.name } and ${ selectedCategory.name }. We\'ve switched your selection to ${ selectedCategory.name }":{"msgid":"You can\'t select both ${ conflictingGlp1Category.name } and ${ selectedCategory.name }. We\'ve switched your selection to ${ selectedCategory.name }","msgstr":["No puedes seleccionar tanto ${ conflictingGlp1Category.name } como ${ selectedCategory.name }. Hemos cambiado tu selección a ${ selectedCategory.name }"]},"No recording available":{"msgid":"No recording available","msgstr":["No hay una grabación disponible"]},"Email sent":{"msgid":"Email sent","msgstr":["Correo enviado"]},"Check your inbox! If an account is registered under that email, you will receive a link to reset your password.":{"msgid":"Check your inbox! If an account is registered under that email, you will receive a link to reset your password.","msgstr":["Revisa tu bandeja de entrada. Si existe una cuenta registrada con ese correo, recibirás un enlace para restablecer tu contraseña."]},"All done!":{"msgid":"All done!","msgstr":["¡Listo!"]},"You can now continue exploring the Fridays experience.":{"msgid":"You can now continue exploring the Fridays experience.","msgstr":["Ahora puedes continuar explorando la experiencia de Fridays."]},"How would you like to get started?":{"msgid":"How would you like to get started?","msgstr":["¿Cómo te gustaría empezar?"]},"You can book a video visit or order your medication without one. Not sure which treatment is right for you? No problem — your provider can help you during your visit.":{"msgid":"You can book a video visit or order your medication without one. Not sure which treatment is right for you? No problem — your provider can help you during your visit.","msgstr":["Puedes reservar una consulta por video o solicitar tu medicación sin una consulta previa. ¿No estás seguro de qué tratamiento es el adecuado para ti? No te preocupes: tu profesional de salud puede orientarte durante la consulta."]},"This is what you\'ve selected to cancel:":{"msgid":"This is what you\'ve selected to cancel:","msgstr":["Esto es lo que seleccionaste para cancelar:"]},"Referral credit":{"msgid":"Referral credit","msgstr":["Crédito de referidos"]},"available to use":{"msgid":"available to use","msgstr":["disponibles para usar"]},"Something went wrong":{"msgid":"Something went wrong","msgstr":["Algo salió mal"]},"Looks like we\'re having trouble launching this page. Please give it a moment and try again. If the problem persists, feel free to contact support.":{"msgid":"Looks like we\'re having trouble launching this page. Please give it a moment and try again. If the problem persists, feel free to contact support.","msgstr":["Tuvimos un problema al cargar esta página. Espera un momento y vuelve a intentarlo. Si el problema continúa, puedes contactar al equipo de soporte."]},"Monthly Auto-Refill":{"msgid":"Monthly Auto-Refill","msgstr":["Reposición automática mensual"]},"3 Month Supply":{"msgid":"3 Month Supply","msgstr":["Suministro para 3 meses"]},"6 Month Supply":{"msgid":"6 Month Supply","msgstr":["Suministro para 6 meses"]},"12 Month Supply":{"msgid":"12 Month Supply","msgstr":["Suministro para 12 meses"]},"Medication Only":{"msgid":"Medication Only","msgstr":["Solo medicación"]}," /mo":{"msgid":" /mo","msgstr":[" /mes"]},"with code":{"msgid":"with code","msgstr":["con el código"]},"One-time purchase":{"msgid":"One-time purchase","msgstr":["Compra única"]},"STARTER BUNDLE":{"msgid":"STARTER BUNDLE","msgstr":["PAQUETE INICIADOR"]},"MOST POPULAR":{"msgid":"MOST POPULAR","msgstr":["MÁS POPULAR"]},"BEST VALUE":{"msgid":"BEST VALUE","msgstr":["MEJOR VALOR"]},"Flexible monthly plan":{"msgid":"Flexible monthly plan","msgstr":["Plan mensual flexible"]},"Maximize results & savings":{"msgid":"Maximize results & savings","msgstr":["Maximiza resultados y ahorros"]},"Visible results start around month 3. Lock in your supply.":{"msgid":"Visible results start around month 3. Lock in your supply.","msgstr":["Los resultados visibles comienzan alrededor del mes 3. Asegura tu suministro."]},"Less than 2 weeks left":{"msgid":"Less than 2 weeks left","msgstr":["Quedan menos de 2 semanas"]},"More than 3 weeks left":{"msgid":"More than 3 weeks left","msgstr":["Quedan más de 3 semanas"]},"Looks like you\'ve got more than 3 weeks left.":{"msgid":"Looks like you\'ve got more than 3 weeks left.","msgstr":["Parece que te quedan más de 3 semanas."]},"Please come back when you have less than 2 weeks, and we\'ll be ready to help you out!":{"msgid":"Please come back when you have less than 2 weeks, and we\'ll be ready to help you out!","msgstr":["Por favor, vuelve cuando te queden menos de 2 semanas y estaremos listos para ayudarte."]},"It appears you have more than 3 weeks left. We will only process a refill if you have less than 2 weeks left at the time of your session":{"msgid":"It appears you have more than 3 weeks left. We will only process a refill if you have less than 2 weeks left at the time of your session","msgstr":["Parece que te quedan más de 3 semanas. Solo procesaremos una recarga si te quedan menos de 2 semanas al momento de tu sesión."]},"None of these apply.":{"msgid":"None of these apply.","msgstr":["Ninguno de estos aplica."]},"None of the below.":{"msgid":"None of the below.","msgstr":["Ninguno de los siguientes."]},"Weight (${ WEIGHT_UNIT[unitSystem] })":{"msgid":"Weight (${ WEIGHT_UNIT[unitSystem] })","msgstr":["Peso (${ WEIGHT_UNIT[unitSystem] })"]},"Check our FAQS":{"msgid":"Check our FAQS","msgstr":["Consulta nuestras preguntas frecuentes"]},"Send us a Message":{"msgid":"Send us a Message","msgstr":["Envíanos un mensaje"]},"Automate your refills to save even more off retail. Pause or cancel anytime.":{"msgid":"Automate your refills to save even more off retail. Pause or cancel anytime.","msgstr":["Automatiza tus recargas para ahorrar aún más en precios minoristas. Pausa o cancela en cualquier momento."]},"Billed quarterly":{"msgid":"Billed quarterly","msgstr":["Facturado trimestralmente"]},"Billed every 6mo":{"msgid":"Billed every 6mo","msgstr":["Facturado cada 6 meses"]},"Billed annually":{"msgid":"Billed annually","msgstr":["Facturado anualmente"]},"Flexible. Pay as you go":{"msgid":"Flexible. Pay as you go","msgstr":["Flexible. Paga según uses"]},"More":{"msgid":"More","msgstr":["Más"]},"Overview":{"msgid":"Overview","msgstr":["Pacientes"]},"Initiate data migration from Healthie":{"msgid":"Initiate data migration from Healthie","msgstr":["Iniciar la migración de datos desde Healthie"]},"Reactivate patient":{"msgid":"Reactivate patient","msgstr":["Reactivar paciente"]},"Reactivate a previously deactivated patient account":{"msgid":"Reactivate a previously deactivated patient account","msgstr":["Reactivar una cuenta de paciente previamente desactivada"]},"Welcome back":{"msgid":"Welcome back","msgstr":["Bienvenido de nuevo"]},"Search":{"msgid":"Search","msgstr":["Buscar"]},"Previous slide":{"msgid":"Previous slide","msgstr":["Diapositiva anterior"]},"Next slide":{"msgid":"Next slide","msgstr":["Siguiente diapositiva"]},"Migrate from Healthie":{"msgid":"Migrate from Healthie","msgstr":["Migrar desde Healthie"]},"Migrate patient":{"msgid":"Migrate patient","msgstr":["Migrar paciente"]},"Patient successfully created! They’ll receive an invitation to log in shortly.":{"msgid":"Patient successfully created! They’ll receive an invitation to log in shortly.","msgstr":["¡Paciente creado correctamente! Recibirá una invitación para iniciar sesión en breve."]},"Use the patient’s Healthie ID to create their profile in the Fridays system. We’ll automatically pull their data to set up the account. Once complete, they’ll receive an email invitation to join.":{"msgid":"Use the patient’s Healthie ID to create their profile in the Fridays system. We’ll automatically pull their data to set up the account. Once complete, they’ll receive an email invitation to join.","msgstr":["Usa el ID de Healthie del paciente para crear su perfil en el sistema de Fridays. Obtendremos automáticamente sus datos para configurar la cuenta. Una vez finalizado el proceso, recibirá un correo electrónico con la invitación para unirse."]},"Healthie ID":{"msgid":"Healthie ID","msgstr":["ID de Healthie"]},"Search by Healthie ID":{"msgid":"Search by Healthie ID","msgstr":["Buscar por ID de Healthie"]},"Use the patient’s Healthie ID to reactivate a previously deactivated profile in the Fridays system. Their account will be restored with their existing data, and they’ll receive a new email invitation to rejoin.":{"msgid":"Use the patient’s Healthie ID to reactivate a previously deactivated profile in the Fridays system. Their account will be restored with their existing data, and they’ll receive a new email invitation to rejoin.","msgstr":["Utilice el ID de Healthie del paciente para reactivar un perfil que haya sido desactivado previamente en el sistema Fridays. La cuenta se restaurará con sus datos existentes y el paciente recibirá una nueva invitación por correo electrónico para volver a unirse."]},"Activate patient":{"msgid":"Activate patient","msgstr":["Activar paciente"]},"Go to patient":{"msgid":"Go to patient","msgstr":["Ir al paciente"]},"Search patient by ID or email":{"msgid":"Search patient by ID or email","msgstr":["Buscar paciente por ID o correo electrónico"]},"Other actions":{"msgid":"Other actions","msgstr":["Otras acciones"]},"Patient details":{"msgid":"Patient details","msgstr":["Detalles del paciente"]},"Details":{"msgid":"Details","msgstr":["Detalles"]},"Subscriptions":{"msgid":"Subscriptions","msgstr":["Suscripciones"]},"Medications":{"msgid":"Medications","msgstr":["Medicamentos"]},"Date of request":{"msgid":"Date of request","msgstr":["Fecha de solicitud"]},"No active medication requests":{"msgid":"No active medication requests","msgstr":["No hay solicitudes de medicamentos activas"]},"No past medication requests":{"msgid":"No past medication requests","msgstr":["No hay solicitudes de medicamentos anteriores"]},"Active":{"msgid":"Active","msgstr":["Activas"]},"Past":{"msgid":"Past","msgstr":["Anteriores"]},"Close":{"msgid":"Close","msgstr":["Cerrar"]},"pagination":{"msgid":"pagination","msgstr":["paginación"]},"Go to previous page":{"msgid":"Go to previous page","msgstr":["Ir a la página anterior"]},"Go to next page":{"msgid":"Go to next page","msgstr":["Ir a la página siguiente"]},"Previous month":{"msgid":"Previous month","msgstr":["Mes anterior"]},"Next month":{"msgid":"Next month","msgstr":["Próximo mes"]},"Select month...":{"msgid":"Select month...","msgstr":["Selecciona mes..."]},"Select year...":{"msgid":"Select year...","msgstr":["Selecciona año..."]},"Documents successfully uploaded!":{"msgid":"Documents successfully uploaded!","msgstr":["¡Documentos subidos exitosamente!"]},"Document preview":{"msgid":"Document preview","msgstr":["Previsualización del documento"]},"Fridays navigation":{"msgid":"Fridays navigation","msgstr":["Navegación de Fridays"]},"Mobile sidebar":{"msgid":"Mobile sidebar","msgstr":["Barra lateral móvil"]},"Open sidebar":{"msgid":"Open sidebar","msgstr":["Abrir barra lateral"]},"Please enter a Healthie ID or email":{"msgid":"Please enter a Healthie ID or email","msgstr":["Por favor ingresa un ID de Healthie o un email"]},"Please enter a valid email address":{"msgid":"Please enter a valid email address","msgstr":["Por favor ingresa un email válido"]},"Healthie ID must contain only numbers":{"msgid":"Healthie ID must contain only numbers","msgstr":["El ID de Healthie debe contener números únicamente"]},"Enter Healthie ID":{"msgid":"Enter Healthie ID","msgstr":["Ingresa un ID de Healthie"]},"Add":{"msgid":"Add","msgstr":["Agregar"]},"Discard changes?":{"msgid":"Discard changes?","msgstr":["¿Descartar cambios?"]},"You have unsaved changes. If you discard now, your edits will be lost.":{"msgid":"You have unsaved changes. If you discard now, your edits will be lost.","msgstr":["Tienes cambios sin guardar. Si los descartas ahora, la información se perdera."]},"Continue editing":{"msgid":"Continue editing","msgstr":["Continuar editando"]},"Enter a valid email address":{"msgid":"Enter a valid email address","msgstr":["Ingrese un casilla de email válido"]},"Main information":{"msgid":"Main information","msgstr":["Información principal"]},"Stripe Customer ID":{"msgid":"Stripe Customer ID","msgstr":["ID de Cliente de Stripe"]},"Email has been successfully updated!":{"msgid":"Email has been successfully updated!","msgstr":["¡El email se ha actualizado correctamente!"]},"Your Healthie ID has been updated!":{"msgid":"Your Healthie ID has been updated!","msgstr":["¡Tu ID de Healthie ha sido actualizado!"]},"Mark intake form as complete?":{"msgid":"Mark intake form as complete?","msgstr":["¿Marcar este formulario como completado?"]},"We couldn\'t find a patient with that ID in Healthie. Please double-check the email address and try again.":{"msgid":"We couldn\'t find a patient with that ID in Healthie. Please double-check the email address and try again.","msgstr":["No pudimos encontrar ningún paciente con esa identificación en Healthie. Por favor, revise la dirección de correo electrónico y vuelva a intentarlo."]},"Paid in Healthie":{"msgid":"Paid in Healthie","msgstr":["Pagado en Healthie"]},"Onboarding":{"msgid":"Onboarding","msgstr":["Onboarding"]},"Intake Form":{"msgid":"Intake Form","msgstr":["Formulario"]},"Mark as Complete":{"msgid":"Mark as Complete","msgstr":["Marcar como Completado"]},"Stripe information":{"msgid":"Stripe information","msgstr":["Información de Stripe"]},"View on Stripe":{"msgid":"View on Stripe","msgstr":["Ver en Stripe"]},"No active subscriptions":{"msgid":"No active subscriptions","msgstr":["No hay suscripciones activas"]},"No past subscriptions":{"msgid":"No past subscriptions","msgstr":["No hay suscripciones pasadas"]},"Expired":{"msgid":"Expired","msgstr":["Vencido"]},"${ subscription.currentProduct.name } intake form has been marked as complete.":{"msgid":"${ subscription.currentProduct.name } intake form has been marked as complete.","msgstr":["El formulario de admisión para ${ subscription.currentProduct.name } ha sido marcado como completado."]},"${ subscription.currentProduct.name } has been marked as active.":{"msgid":"${ subscription.currentProduct.name } has been marked as active.","msgstr":["${ subscription.currentProduct.name } ha sido marcado como activo."]},"Update to Active":{"msgid":"Update to Active","msgstr":["Activar"]},"You\'re about to mark this intake form as complete. This action is irreversible. Once confirmed, the patient will gain full access to the platform.":{"msgid":"You\'re about to mark this intake form as complete. This action is irreversible. Once confirmed, the patient will gain full access to the platform.","msgstr":["Está a punto de marcar este formulario de admisión como completado. Esta acción es irreversible. Una vez confirmado, el paciente tendrá acceso completo a la plataforma."]},"Update to active?":{"msgid":"Update to active?","msgstr":["¿Actualizar a Activo?"]},"Stripe failure":{"msgid":"Stripe failure","msgstr":["Falla de Stripe"]},"Medication request has been successfully updated!":{"msgid":"Medication request has been successfully updated!","msgstr":["¡La solicitud de medicamento ha sido actualizada exitosamente!"]},"Please check the form for errors":{"msgid":"Please check the form for errors","msgstr":["Por favor, revisa el formulario por errores"]},"You\'re about to make this subscription active. This action is irreversible. Once confirmed, the patient will gain full access to the platform.":{"msgid":"You\'re about to make this subscription active. This action is irreversible. Once confirmed, the patient will gain full access to the platform.","msgstr":["Estás a punto de marcar esta suscripción como activa. Esta acción es irreversible. Una vez confirmado, el paciente tendrá acceso completo a la plataforma."]},"No failed subscriptions":{"msgid":"No failed subscriptions","msgstr":["No hay suscripciones fallidas"]},"Patient successfully reactivated! They can now log in or request a new password if needed.":{"msgid":"Patient successfully reactivated! They can now log in or request a new password if needed.","msgstr":["¡Paciente reactivado con éxito! Ahora pueden iniciar sesión o solicitar una nueva contraseña si es necesario."]},"Back to Log in":{"msgid":"Back to Log in","msgstr":["Volver a iniciar sesión"]},"month(s)":{"msgid":"month(s)","msgstr":["mes(es)"]},"Recurring":{"msgid":"Recurring","msgstr":["Recurrente"]},"Billing type":{"msgid":"Billing type","msgstr":["Tipo de facturación"]},"Billing cycle":{"msgid":"Billing cycle","msgstr":["Ciclo de facturación"]},"${ subscription.currentProduct.price.durationInMonths } month(s) plan":{"msgid":"${ subscription.currentProduct.price.durationInMonths } month(s) plan","msgstr":["Plan de ${ subscription.currentProduct.price.durationInMonths } mes(es)"]},"In partnership with Happy Sleep":{"msgid":"In partnership with Happy Sleep","msgstr":["En asociación con Happy Sleep"]},"Not feeling fully rested?":{"msgid":"Not feeling fully rested?","msgstr":["¿No te sientes completamente descansado?"]},"Snoring, low energy, or waking up tired could be signs of a sleep disorder.":{"msgid":"Snoring, low energy, or waking up tired could be signs of a sleep disorder.","msgstr":["Los ronquidos, la falta de energía o despertarse cansado podrían ser signos de un trastorno del sueño."]},"Log in":{"msgid":"Log in","msgstr":["Iniciar sesión"]},"Enter your details below to continue.":{"msgid":"Enter your details below to continue.","msgstr":["Ingresa tus datos a continuación para continuar."]},"Fridays does not manufacture compounded medications. Actual product appearance and labeling of the medication you receive will differ from website images.":{"msgid":"Fridays does not manufacture compounded medications. Actual product appearance and labeling of the medication you receive will differ from website images.","msgstr":["Fridays no fabrica medicamentos compuestos. El aspecto real y el etiquetado del medicamento que recibas pueden diferir de las imágenes del sitio web."]},"$${ nextBillingAmount } on next period (${ formattedNextBillingDate })":{"msgid":"$${ nextBillingAmount } on next period (${ formattedNextBillingDate })","msgstr":["$${ nextBillingAmount } en el siguiente período (${ formattedNextBillingDate })"]},"(Excludes Savings & Support)":{"msgid":"(Excludes Savings & Support)","msgstr":["(Excluye ahorros y soporte)"]},"Forfeit: dedicated coaching, the companion app, and bundled discounts.":{"msgid":"Forfeit: dedicated coaching, the companion app, and bundled discounts.","msgstr":["Pierdes: acompañamiento dedicado, la aplicación complementaria y descuentos agrupados."]},"1 Month Supply":{"msgid":"1 Month Supply","msgstr":["Suministro para 1 mes"]},"Fridays has partnered with Happy Sleep":{"msgid":"Fridays has partnered with Happy Sleep","msgstr":["Fridays se ha asociado con Happy Sleep"]},"Check if you qualify":{"msgid":"Check if you qualify","msgstr":["Verifica si calificas"]},"Struggling with snoring or poor sleep?":{"msgid":"Struggling with snoring or poor sleep?","msgstr":["¿Luchas contra los ronquidos o el mal dormir?"]},"New Partnership!":{"msgid":"New Partnership!","msgstr":["¡Nueva asociación!"]},"Energy & Sleep":{"msgid":"Energy & Sleep","msgstr":["Energía y Sueño"]},"You don\'t have any past medication requests":{"msgid":"You don\'t have any past medication requests","msgstr":["No tienes solicitudes de medicamentos anteriores"]},"We\'re so excited for your next phase!":{"msgid":"We\'re so excited for your next phase!","msgstr":["¡Estamos muy emocionados por tu próxima fase!"]},"We\'re here to guide you step by step so you know what\'s normal, what to expect, and what to do next.":{"msgid":"We\'re here to guide you step by step so you know what\'s normal, what to expect, and what to do next.","msgstr":["Estamos aquí para guiarte paso a paso para que sepas qué es normal, qué esperar y qué hacer a continuación."]},"Thanks for completing your initial screening questions. Now we want to understand how to best support your ongoing journey — this helps us personalize your care, guidance, and recommendations.":{"msgid":"Thanks for completing your initial screening questions. Now we want to understand how to best support your ongoing journey — this helps us personalize your care, guidance, and recommendations.","msgstr":["Gracias por completar tus preguntas de evaluación inicial. Ahora queremos entender cómo apoyar mejor tu camino continuo, esto nos ayuda a personalizar tu atención, orientación y recomendaciones."]},"Meet the ring that can explain your sleep in the Fridays Shop":{"msgid":"Meet the ring that can explain your sleep in the Fridays Shop","msgstr":["Conoce el anillo que puede explicar tu sueño en la Tienda de Fridays"]},"Before you go, here\'s what to know:":{"msgid":"Before you go, here\'s what to know:","msgstr":["Antes de irte, aquí está lo que debes saber:"]},"Your access continues through":{"msgid":"Your access continues through","msgstr":["Tu acceso continúa hasta"]},"Your current billing period is non-refundable":{"msgid":"Your current billing period is non-refundable","msgstr":["Tu periodo de facturación actual no es reembolsable"]},", this cancellation must be submitted at least 72 hours before":{"msgid":", this cancellation must be submitted at least 72 hours before","msgstr":[", esta cancelación debe ser enviada al menos 72 horas antes de"]},"To avoid your next charge of":{"msgid":"To avoid your next charge of","msgstr":["Para evitar tu próximo cargo de"]},"All from home, for as little as $0.":{"msgid":"All from home, for as little as $0.","msgstr":["Todo desde casa, por tan solo $0."]},"Swipe down to close":{"msgid":"Swipe down to close","msgstr":["Desliza hacia abajo para cerrar"]},"${ partnershipStrong } to offer a sleek FDA-cleared wearable that tracks your sleep and access board-certified sleep doctors. ${ allFromHomeStrong }":{"msgid":"${ partnershipStrong } to offer a sleek FDA-cleared wearable that tracks your sleep and access board-certified sleep doctors. ${ allFromHomeStrong }","msgstr":["${ partnershipStrong } para ofrecer un elegante dispositivo autorizado por la FDA que controla tu sueño y acceso a médicos del sueño certificados. ${ allFromHomeStrong }"]},"Fridays has partnered with Happy Sleep to offer a sleek FDA-cleared wearable that tracks your sleep and access board-certified sleep doctors. All from home, for as little as $0.":{"msgid":"Fridays has partnered with Happy Sleep to offer a sleek FDA-cleared wearable that tracks your sleep and access board-certified sleep doctors. All from home, for as little as $0.","msgstr":["Fridays se ha asociado con Happy Sleep para ofrecer un elegante dispositivo autorizado por la FDA que controla tu sueño y acceso a médicos del sueño certificados. Todo desde casa, por tan solo $0."]},"Spring Sale":{"msgid":"Spring Sale","msgstr":["Descuentos de Primavera"]},"Open appointment menu":{"msgid":"Open appointment menu","msgstr":["Abrir menú de cita"]},"Vendor":{"msgid":"Vendor","msgstr":["Proveedor"]},"Phone consultation required":{"msgid":"Phone consultation required","msgstr":["Consulta telefónica requerida"]},"Based on your state\'s requirements, a phone consultation is required before starting treatment. After you submit your intake form, you\'ll receive a call from one of our providers to complete your visit. Keep an eye out - we\'ll be in touch soon!":{"msgid":"Based on your state\'s requirements, a phone consultation is required before starting treatment. After you submit your intake form, you\'ll receive a call from one of our providers to complete your visit. Keep an eye out - we\'ll be in touch soon!","msgstr":["Según los requisitos de tu estado, se requiere una consulta telefónica antes de comenzar el tratamiento. Después de enviar tu formulario de admisión, recibirás una llamada de uno de nuestros profesionales para completar tu consulta. ¡Estate atento, nos comunicaremos pronto!"]},"OpenLoop ID":{"msgid":"OpenLoop ID","msgstr":["ID de OpenLoop"]},"WhiteCoat ID":{"msgid":"WhiteCoat ID","msgstr":["ID de WhiteCoat"]},"Get $${ REFERRAL_RECEIVE_CREDIT_AMOUNT } in credit":{"msgid":"Get $${ REFERRAL_RECEIVE_CREDIT_AMOUNT } in credit","msgstr":["Obtén $${ REFERRAL_RECEIVE_CREDIT_AMOUNT } en crédito"]},"Share your code — your friends and family get $${ REFERRAL_GIVE_CREDIT_AMOUNT } off, and you\'ll earn $${ REFERRAL_RECEIVE_CREDIT_AMOUNT } in credit when they join with this unique referral code!":{"msgid":"Share your code — your friends and family get $${ REFERRAL_GIVE_CREDIT_AMOUNT } off, and you\'ll earn $${ REFERRAL_RECEIVE_CREDIT_AMOUNT } in credit when they join with this unique referral code!","msgstr":["Comparte tu código: tus amigos y familiares reciben $${ REFERRAL_GIVE_CREDIT_AMOUNT } de descuento, ¡y tú ganas $${ REFERRAL_RECEIVE_CREDIT_AMOUNT } en crédito cuando se unan con este código de referencia único!"]},"Keep it up, ":{"msgid":"Keep it up, ","msgstr":["Sigue adelante, "]},"By entering your email, we\'ll save your progress and send you updates about your care. We may also send you occasional promotions via email. You can unsubscribe anytime. View our ${ termsAndConditionsLink }.":{"msgid":"By entering your email, we\'ll save your progress and send you updates about your care. We may also send you occasional promotions via email. You can unsubscribe anytime. View our ${ termsAndConditionsLink }.","msgstr":["Al ingresar tu correo electrónico, guardaremos tu progreso y te enviaremos novedades sobre tu atención. También podemos enviarte promociones ocasionales por correo electrónico. Puedes darte de baja en cualquier momento. Consulta nuestros ${ termsAndConditionsLink }."]},"RECOMMENDED":{"msgid":"RECOMMENDED","msgstr":["RECOMENDADO"]},"Bundle Savings":{"msgid":"Bundle Savings","msgstr":["Ahorros de paquete"]},"Shipping":{"msgid":"Shipping","msgstr":["Envío"]},"(Premium Cold-Packs)":{"msgid":"(Premium Cold-Packs)","msgstr":["(Paquetes fríos premium)"]},"TOTAL SAVINGS":{"msgid":"TOTAL SAVINGS","msgstr":["AHORRO TOTAL"]},"Recurring subtotal":{"msgid":"Recurring subtotal","msgstr":["Subtotal recurrente"]},"${ formattedSubtotal } every ${ sharedRecurringDuration } months":{"msgid":"${ formattedSubtotal } every ${ sharedRecurringDuration } months","msgstr":["${ formattedSubtotal } cada ${ sharedRecurringDuration } meses"]},"Special Discount":{"msgid":"Special Discount","msgstr":["Descuento especial"]},"Remove discount code":{"msgid":"Remove discount code","msgstr":["Eliminar código de descuento"]},"Select your Weight Loss Plan":{"msgid":"Select your Weight Loss Plan","msgstr":["Selecciona tu plan de pérdida de peso"]},"Select your ${ categoryName } Plan":{"msgid":"Select your ${ categoryName } Plan","msgstr":["Selecciona tu plan de ${ categoryName }"]},"Pay Full Retail (No Refill)":{"msgid":"Pay Full Retail (No Refill)","msgstr":["Pagar precio completo (Sin reabastecimiento)"]},"4 Month Supply":{"msgid":"4 Month Supply","msgstr":["Suministro de 4 meses"]},"Billed every 4mo":{"msgid":"Billed every 4mo","msgstr":["Facturado cada 4 meses"]},"Single month only. One-time purchase":{"msgid":"Single month only. One-time purchase","msgstr":["Solo un mes. Compra única"]},"Excludes all coaching, app access, and savings.":{"msgid":"Excludes all coaching, app access, and savings.","msgstr":["Excluye todo coaching, acceso a la aplicación y ahorros."]},"on next month (Included in your offer)":{"msgid":"on next month (Included in your offer)","msgstr":["el próximo mes (Incluido en tu oferta)"]},"4-Month":{"msgid":"4-Month","msgstr":["4 meses"]},"I agree to the ${ termsAndConditionsLink }, consent to the ${ privacyPolicyLink }, ${ openLoopTelehealthConsentLink } & ${ whitecoatTermsAndConditionsLinks }.  Regardless of my choices above, I agree to get non-marketing emails, text messages, and/or calls from Fridays relating to my account (for example, appointment reminders).":{"msgid":"I agree to the ${ termsAndConditionsLink }, consent to the ${ privacyPolicyLink }, ${ openLoopTelehealthConsentLink } & ${ whitecoatTermsAndConditionsLinks }.  Regardless of my choices above, I agree to get non-marketing emails, text messages, and/or calls from Fridays relating to my account (for example, appointment reminders).","msgstr":["Acepto los ${ termsAndConditionsLink }, doy mi consentimiento para la ${ privacyPolicyLink }, ${ openLoopTelehealthConsentLink } y ${ whitecoatTermsAndConditionsLinks }. Independientemente de mis elecciones anteriores, acepto recibir correos electrónicos, mensajes de texto y/o llamadas no promocionales de Fridays relacionadas con mi cuenta (por ejemplo, recordatorios de citas)."]},"EXTRA $${ amountOff } OFF":{"msgid":"EXTRA $${ amountOff } OFF","msgstr":["EXTRA $${ amountOff } DE DESCUENTO"]},"Get every 4th month free":{"msgid":"Get every 4th month free","msgstr":["Obtén cada 4to mes gratis"]},"Please enter up to one decimal place":{"msgid":"Please enter up to one decimal place","msgstr":["Por favor ingrese hasta un decimal"]},"Must be ${ MAX_LENGTH_NAME } characters or less":{"msgid":"Must be ${ MAX_LENGTH_NAME } characters or less","msgstr":["Debe tener ${ MAX_LENGTH_NAME } caracteres o menos"]},"Due to age requirements in your state, we\'re unable to create your Fridays account right now. We\'re sorry we can\'t support you at this time.":{"msgid":"Due to age requirements in your state, we\'re unable to create your Fridays account right now. We\'re sorry we can\'t support you at this time.","msgstr":["Debido a los requisitos de edad en tu estado, no podemos crear tu cuenta de Fridays en este momento. Lamentamos no poder apoyarte en esta ocasión."]},"E.g. 286.2":{"msgid":"E.g. 286.2","msgstr":["Ej. 286.2"]},"E.g. 128.5":{"msgid":"E.g. 128.5","msgstr":["Ej. 128.5"]},"I understand that my plan will be cancelled on ":{"msgid":"I understand that my plan will be cancelled on ","msgstr":["Entiendo que mi plan será cancelado el "]},". For more information see ${ termsAndConditionsLink }":{"msgid":". For more information see ${ termsAndConditionsLink }","msgstr":[". Para más información, consulta ${ termsAndConditionsLink }"]},"Your ${ displayName } intake is already complete":{"msgid":"Your ${ displayName } intake is already complete","msgstr":["Tu intake de ${ displayName } ya está completo"]},"It looks like your account doesn\'t have the required permissions. Please contact support for assistance.":{"msgid":"It looks like your account doesn\'t have the required permissions. Please contact support for assistance.","msgstr":["Parece que tu cuenta no tiene los permisos necesarios. Por favor contacta a soporte para recibir asistencia."]},"Go to log in":{"msgid":"Go to log in","msgstr":["Ir a iniciar sesión"]},"Pay with":{"msgid":"Pay with","msgstr":["Pagar con"]},"${ durationInMonths }-month supply":{"msgid":"${ durationInMonths }-month supply","msgid_plural":"${ durationInMonths }-month supply","msgstr":["Plan de ${ durationInMonths } mes","Plan de ${ durationInMonths } meses"]},"Amount must be a number":{"msgid":"Amount must be a number","msgstr":["La cantidad debe ser un número"]},"Amount must be a whole number":{"msgid":"Amount must be a whole number","msgstr":["La cantidad debe ser un número entero"]},"Amount must be at least $${ MIN_AMOUNT }":{"msgid":"Amount must be at least $${ MIN_AMOUNT }","msgstr":["La cantidad debe ser al menos $${ MIN_AMOUNT }"]},"Amount must be at most $${ MAX_AMOUNT }":{"msgid":"Amount must be at most $${ MAX_AMOUNT }","msgstr":["La cantidad debe ser como máximo $${ MAX_AMOUNT }"]},"available credit":{"msgid":"available credit","msgstr":["crédito disponible"]},"Add credit":{"msgid":"Add credit","msgstr":["Agregar crédito"]},"Credit adjustment":{"msgid":"Credit adjustment","msgstr":["Ajuste de crédito"]},"Credit added successfully! ${ details.firstName }\'s available balance has been updated to $${ availableBalance }.":{"msgid":"Credit added successfully! ${ details.firstName }\'s available balance has been updated to $${ availableBalance }.","msgstr":["¡Crédito agregado correctamente! El saldo disponible de ${ details.firstName } se actualizó a $${ availableBalance }."]},"Credit couldn\'t be added. Please try again.":{"msgid":"Credit couldn\'t be added. Please try again.","msgstr":["No se pudo agregar el crédito. Por favor, inténtalo de nuevo."]},"Pill (Oral)":{"msgid":"Pill (Oral)","msgstr":["Píldora (Oral)"]},"Pen (Injection)":{"msgid":"Pen (Injection)","msgstr":["Pluma (Inyección)"]},"Spray (Nasal)":{"msgid":"Spray (Nasal)","msgstr":["Spray (Nasal)"]},"Automate your care to lock in the lowest rates. Pause or cancel anytime.":{"msgid":"Automate your care to lock in the lowest rates. Pause or cancel anytime.","msgstr":["Automatiza tu cuidado para asegurar las tarifas más bajas. Pausa o cancela en cualquier momento."]},"Wegovy® Medication Pricing":{"msgid":"Wegovy® Medication Pricing","msgstr":["Precios del medicamento Wegovy®"]},"Delivery":{"msgid":"Delivery","msgstr":["Entrega"]},"Dosage":{"msgid":"Dosage","msgstr":["Dosis"]},"Monthly Price":{"msgid":"Monthly Price","msgstr":["Precio mensual"]},"Other Plan Options":{"msgid":"Other Plan Options","msgstr":["Otras opciones de plan"]},"Basic Rx Access. ":{"msgid":"Basic Rx Access. ","msgstr":["Acceso básico a Rx. "]},"Temporary Rx bridge. Not for new journeys. Visible results start around month 3.":{"msgid":"Temporary Rx bridge. Not for new journeys. Visible results start around month 3.","msgstr":["Puente de Rx temporal. No para nuevos tratamientos. Los resultados visibles comienzan alrededor del mes 3."]},"THE STARTER":{"msgid":"THE STARTER","msgstr":["EL INICIO"]},"1 Month Consultation":{"msgid":"1 Month Consultation","msgstr":["Consulta de 1 mes"]},"3-Month Breakthrough":{"msgid":"3-Month Breakthrough","msgstr":["Avance de 3 meses"]},"6-Month Momentum":{"msgid":"6-Month Momentum","msgstr":["Impulso de 6 meses"]},"12-Month Transformation":{"msgid":"12-Month Transformation","msgstr":["Transformación de 12 meses"]},"For beginners starting medical weight loss.":{"msgid":"For beginners starting medical weight loss.","msgstr":["Para principiantes que comienzan la pérdida de peso médica."]},"For those committed to compounding results.":{"msgid":"For those committed to compounding results.","msgstr":["Para quienes están comprometidos a potenciar resultados."]},"For those seeking a lasting transformation":{"msgid":"For those seeking a lasting transformation","msgstr":["Para quienes buscan una transformación duradera"]},"Billed today":{"msgid":"Billed today","msgstr":["Facturado hoy"]},"Injection":{"msgid":"Injection","msgstr":["Inyección"]},"Daily Pill":{"msgid":"Daily Pill","msgstr":["Píldora diaria"]},"Once-a-week injections":{"msgid":"Once-a-week injections","msgstr":["Inyecciones una vez a la semana"]},"Once-daily oral dose.":{"msgid":"Once-daily oral dose.","msgstr":["Dosis oral una vez al día."]},"No needles":{"msgid":"No needles","msgstr":["Sin agujas"]},"SELECTED":{"msgid":"SELECTED","msgstr":["SELECCIONADO"]},"SELECT":{"msgid":"SELECT","msgstr":["SELECCIONAR"]},"Review Your Medication":{"msgid":"Review Your Medication","msgstr":["Revisa tu medicación"]},"100% Transparent Billing:":{"msgid":"100% Transparent Billing:","msgstr":["Facturación 100% transparente:"]},"Today you are only billed for your Membership Plan to guarantee your clinical care. Your GLP-1 medication is billed separately at the pharmacy cash-pay rate (starting at $149/mo) only after your provider officially approves your treatment protocol. Zero hidden fees.":{"msgid":"Today you are only billed for your Membership Plan to guarantee your clinical care. Your GLP-1 medication is billed separately at the pharmacy cash-pay rate (starting at $149/mo) only after your provider officially approves your treatment protocol. Zero hidden fees.","msgstr":["Hoy solo se te factura por tu Plan de Membresía para garantizar tu atención clínica. Tu medicamento GLP-1 se factura por separado a la tarifa de pago en efectivo de la farmacia (a partir de $149/mes) solo después de que tu proveedor apruebe oficialmente tu protocolo de tratamiento. Cero tarifas ocultas."]},"Pay only $${ FIRST_MONTH_PRICE } your first month.":{"msgid":"Pay only $${ FIRST_MONTH_PRICE } your first month.","msgstr":["Paga solo $${ FIRST_MONTH_PRICE } tu primer mes."]},"Renews at ${ formattedPrice }/mo.":{"msgid":"Renews at ${ formattedPrice }/mo.","msgstr":["Renueva a ${ formattedPrice }/mes."]},"Billed separately by pharmacy. Dosage prescribed based on individual consultation.":{"msgid":"Billed separately by pharmacy. Dosage prescribed based on individual consultation.","msgstr":["Facturado por separado por la farmacia. Dosificación prescrita según consulta individual."]},"Please review and complete all required acknowledgments.":{"msgid":"Please review and complete all required acknowledgments.","msgstr":["Por favor, revise y complete todos los reconocimientos requeridos."]},"I authorize OpenLoop Healthcare Partners, PC to securely store my payment method and charge it for services I request (visits, prescriptions, refills, follow-up care) as well as on a recurring basis for any subscription I select. I understand charges may occur after services are rendered, that recurring charges continue until | cancel per the cancellation policy, and that I am responsible for all disclosed fees.":{"msgid":"I authorize OpenLoop Healthcare Partners, PC to securely store my payment method and charge it for services I request (visits, prescriptions, refills, follow-up care) as well as on a recurring basis for any subscription I select. I understand charges may occur after services are rendered, that recurring charges continue until | cancel per the cancellation policy, and that I am responsible for all disclosed fees.","msgstr":["Autorizo a OpenLoop Healthcare Partners, PC a almacenar de forma segura mi método de pago y a cobrarlo por los servicios que solicito (visitas, recetas, recargas, atención de seguimiento), así como de forma recurrente por cualquier suscripción que seleccione. Entiendo que los cargos pueden producirse después de que se presten los servicios, que los cargos recurrentes continúan hasta que los cancele según la política de cancelación, y que soy responsable de todas las tarifas divulgadas."]},"I confirm I am NOT enrolled in any government-funded medical or prescription benefit program (e.g., Medicare, Medigap, VA, DOD, TRICARE, Medicaid, or any other state/federal medical or pharmaceutical benefit or assistance program). Having both commercial and government-funded plans counts as government insurance. If you begin receiving prescription benefits under any government plan, you understand you can no longer participate in this program.":{"msgid":"I confirm I am NOT enrolled in any government-funded medical or prescription benefit program (e.g., Medicare, Medigap, VA, DOD, TRICARE, Medicaid, or any other state/federal medical or pharmaceutical benefit or assistance program). Having both commercial and government-funded plans counts as government insurance. If you begin receiving prescription benefits under any government plan, you understand you can no longer participate in this program.","msgstr":["Confirmo que NO estoy inscrito en ningún programa de beneficios médicos o de prescripción financiado por el gobierno (por ejemplo, Medicare, Medigap, VA, DOD, TRICARE, Medicaid, o cualquier otro programa estatal/federal de beneficios o asistencia médica o farmacéutica). Tener planes comerciales y financiados por el gobierno cuenta como seguro gubernamental. Si comienza a recibir beneficios de prescripción bajo cualquier plan gubernamental, comprende que ya no podrá participar en este programa."]},"Wegovy® Pill: Pricing starts at $149/month for 1.5 mg and 4 mg doses (Note: The 4 mg dose increases to $199/month after April 15, 2026). Higher doses of 9 mg and 25 mg are $299/month. Additional terms and restrictions apply.":{"msgid":"Wegovy® Pill: Pricing starts at $149/month for 1.5 mg and 4 mg doses (Note: The 4 mg dose increases to $199/month after April 15, 2026). Higher doses of 9 mg and 25 mg are $299/month. Additional terms and restrictions apply.","msgstr":["Wegovy® Pill: El precio comienza en $149/mes para dosis de 1,5 mg y 4 mg (nota: la dosis de 4 mg aumenta a $199/mes después del 15 de abril de 2026). Las dosis más altas de 9 mg y 25 mg cuestan $299/mes. Se aplican términos y restricciones adicionales."]},"Payment Agreement":{"msgid":"Payment Agreement","msgstr":["Acuerdo de pago"]},"By selecting “Pay”, you agree to the following ${ paymentAgreementLink }":{"msgid":"By selecting “Pay”, you agree to the following ${ paymentAgreementLink }","msgstr":["Al seleccionar “Pagar”, aceptas lo siguiente ${ paymentAgreementLink }"]},"Fuze Health Terms of use":{"msgid":"Fuze Health Terms of use","msgstr":["Términos de uso de Fuze Health"]},"Notice of HIPAA Privacy Practices":{"msgid":"Notice of HIPAA Privacy Practices","msgstr":["Aviso de prácticas de privacidad HIPAA"]},"Privacy Policy":{"msgid":"Privacy Policy","msgstr":["Política de privacidad"]},"I agree to the ${ termsAndConditionsLink }, consent to the ${ privacyPolicyLink }, ${ openLoopTelehealthConsentLink } & ${ whitecoatTermsAndConditionsLinks }. I agree to get non-marketing emails, text messages, and/or calls from Fridays relating to my account. I acknowledge and agree to the ${ fuzeHealthTermsOfUseLink }, ${ fuzeHipaaPrivacyPracticesLink }, and ${ fuzePrivacyPolicyLink }":{"msgid":"I agree to the ${ termsAndConditionsLink }, consent to the ${ privacyPolicyLink }, ${ openLoopTelehealthConsentLink } & ${ whitecoatTermsAndConditionsLinks }. I agree to get non-marketing emails, text messages, and/or calls from Fridays relating to my account. I acknowledge and agree to the ${ fuzeHealthTermsOfUseLink }, ${ fuzeHipaaPrivacyPracticesLink }, and ${ fuzePrivacyPolicyLink }","msgstr":["Estoy de acuerdo con los ${ termsAndConditionsLink }, doy mi consentimiento a los ${ privacyPolicyLink }, ${ openLoopTelehealthConsentLink } y ${ whitecoatTermsAndConditionsLinks }. Acepto recibir correos electrónicos, mensajes de texto y/o llamadas no comerciales de Fridays relacionados con mi cuenta. Reconozco y acepto los ${ fuzeHealthTermsOfUseLink }, ${ fuzeHipaaPrivacyPracticesLink } y ${ fuzePrivacyPolicyLink }"]},"We\'re excited to introduce ${ journeySupportStrong }, an exciting new feature offering personalized coaching with a Certified Medical Assistant to help you set goals, navigate challenges, and stay on track. It\'s an optional extra boost to keep you moving forward — you can book a ${ freeStrong } session anytime!":{"msgid":"We\'re excited to introduce ${ journeySupportStrong }, an exciting new feature offering personalized coaching with a Certified Medical Assistant to help you set goals, navigate challenges, and stay on track. It\'s an optional extra boost to keep you moving forward — you can book a ${ freeStrong } session anytime!","msgstr":["Estamos emocionados de presentar ${ journeySupportStrong }, una nueva función emocionante que ofrece coaching personalizado con un asistente médico certificado para ayudarte a establecer metas, afrontar desafíos y mantener el rumbo. Es un impulso adicional opcional para que sigas avanzando: ¡puedes reservar una sesión ${ freeStrong } en cualquier momento!"]},"for ${ price.discount.durationInMonths } month(s)":{"msgid":"for ${ price.discount.durationInMonths } month(s)","msgstr":["por ${ price.discount.durationInMonths } mes(es)"]},"Sessions successfully deleted!":{"msgid":"Sessions successfully deleted!","msgstr":["Sesiones borradas!"]},"Sessions successfully updated!":{"msgid":"Sessions successfully updated!","msgstr":["Sessiones actualizadas!"]},"${ selectedCount } of ${ totalCount } selected":{"msgid":"${ selectedCount } of ${ totalCount } selected","msgstr":["${ selectedCount } de ${ totalCount } seleccionadas"]},"${ totalCount } sessions":{"msgid":"${ totalCount } sessions","msgstr":["${ totalCount } sesiones"]},"Clear selection":{"msgid":"Clear selection","msgstr":["Limpiar selección"]},"Keep current":{"msgid":"Keep current","msgstr":["Mantener actual"]},"Apply changes":{"msgid":"Apply changes","msgstr":["Aplicar cambios"]},"Confirm address update":{"msgid":"Confirm address update","msgstr":["Confirmar actualización de dirección"]},"You\'re about to update your shipping address. You have an active order already being processed. That order will still be shipped to your previous address, while your updated address will apply to future shipments.":{"msgid":"You\'re about to update your shipping address. You have an active order already being processed. That order will still be shipped to your previous address, while your updated address will apply to future shipments.","msgstr":["Estás a punto de actualizar tu dirección de envío. Tienes un pedido activo que ya está siendo procesado. Ese pedido se enviará a tu dirección anterior, mientras que tu nueva dirección se aplicará a los envíos futuros."]},"Address updated! Future orders will ship to your new address.":{"msgid":"Address updated! Future orders will ship to your new address.","msgstr":["¡Dirección actualizada! Los pedidos futuros se enviarán a tu nueva dirección."]},"Invoiced":{"msgid":"Invoiced","msgstr":["Facturado"]},"Shipped":{"msgid":"Shipped","msgstr":["Enviado"]},"The medication has been invoiced and is being prepared for delivery.":{"msgid":"The medication has been invoiced and is being prepared for delivery.","msgstr":["El medicamento ha sido facturado y está siendo preparado para el envío."]},"Your medication has been shipped and is on its way.":{"msgid":"Your medication has been shipped and is on its way.","msgstr":["Tu medicamento ha sido enviado y está en camino."]},"Apply to ${ count } session":{"msgid":"Apply to ${ count } session","msgid_plural":"Apply to ${ count } sessions","msgstr":["Aplicar a ${ count } sesión","Aplicar a ${ count } sesiones"]},"Delete ${ count } session":{"msgid":"Delete ${ count } session","msgid_plural":"Delete ${ count } sessions","msgstr":["Eliminar ${ count } sesión","Eliminar ${ count } sesiones"]},"You are about to delete ${ count } session. Published sessions with enrolled users will trigger cancellation emails. Are you sure you want to proceed?":{"msgid":"You are about to delete ${ count } session. Published sessions with enrolled users will trigger cancellation emails. Are you sure you want to proceed?","msgid_plural":"You are about to delete ${ count } sessions. Published sessions with enrolled users will trigger cancellation emails. Are you sure you want to proceed?","msgstr":["Estás por eliminar ${ count } sesión. Las sesiones publicadas con usuarios inscritos enviarán correos de cancelación. ¿Seguro que quieres continuar?","Estás por eliminar ${ count } sesiones. Las sesiones publicadas con usuarios inscritos enviarán correos de cancelación. ¿Seguro que quieres continuar?"]},"Edit ${ count } session":{"msgid":"Edit ${ count } session","msgid_plural":"Edit ${ count } sessions","msgstr":["Editar ${ count } sesión","Editar ${ count } sesiones"]},"Apply changes to ${ count } session?":{"msgid":"Apply changes to ${ count } session?","msgid_plural":"Apply changes to ${ count } sessions?","msgstr":["¿Aplicar cambios a ${ count } sesión?","¿Aplicar cambios a ${ count } sesiones?"]},"You\'re about to update ${ count } selected session. Only the fields you changed will be applied. All other fields will stay the same.":{"msgid":"You\'re about to update ${ count } selected session. Only the fields you changed will be applied. All other fields will stay the same.","msgid_plural":"You\'re about to update ${ count } selected sessions. Only the fields you changed will be applied. All other fields will stay the same.","msgstr":["Estás a punto de actualizar ${ count } sesión seleccionada. Solo se aplicarán los campos que modificaste. Los demás campos quedarán igual.","Estás a punto de actualizar ${ count } sesiones seleccionadas. Solo se aplicarán los campos que modificaste. Los demás campos quedarán igual."]},"Complete only the fields you want to update. Fields left as “Keep current” will not be changed.":{"msgid":"Complete only the fields you want to update. Fields left as “Keep current” will not be changed.","msgstr":["Completa solo los campos que quieres actualizar. Los campos que se dejen como “Mantener actual” no se modificarán."]}}}'),hJt={charset:dJt,headers:fJt,translations:mJt};XMe({dsn:Li.VITE_SENTRY_DSN_PUBLIC,environment:Li.VITE_SENTRY_ENVIRONMENT,tracesSampleRate:0,replaysSessionSampleRate:0,replaysOnErrorSampleRate:0,beforeSend:e=>{var t,n;return(t=e.request)!=null&&t.url&&(e.request.url=e.request.url.split("?")[0]),((n=e.request)==null?void 0:n.query_string)!==void 0&&(e.request.query_string="[FILTERED]"),e.breadcrumbs&&(e.breadcrumbs=e.breadcrumbs.filter(r=>!["ui.input","console"].includes(r.category??""))),e}});wqe("es",hJt);const pJt=RQt(Li.VITE_STRIPE_PUBLIC_KEY),gJt=()=>{const e=X2t(),t=Vvt(ir.ANALYTICS);RZe(),gyt();const n=C.useMemo(()=>t?EQt.load({writeKey:Li.VITE_CUSTOMER_IO_WRITE_KEY}):null,[t]);return s.jsx(UQt,{children:s.jsx(eV,{stripe:pJt,options:{locale:e},children:s.jsx(Fvt,{analytics:n,children:s.jsx(A$e,{router:EKt},e)})})})};let qk=null;document.addEventListener("DOMContentLoaded",()=>{qk||(qk=document.getElementById("app"),GDe.createRoot(qk).render(s.jsx(J.StrictMode,{children:s.jsxs(ODe,{client:Th,children:[s.jsx(uJt,{}),s.jsx(nDe,{fallback:s.jsx(wg,{}),children:s.jsx(gJt,{})}),d$.createPortal(s.jsx(jvt,{}),document.body),Li.VITE_APP_ENV===Iz.LOCAL&&s.jsx(zDe,{initialIsOpen:!1})]})})))});export{N4 as C,yG as P,an as _,En as a,ss as b,ft as c,FNe as d,vh as e,hen as f,pen as g,EG as h,LS as i,F7 as j,_3 as k,Dk as l,NXt as m,AKt as n,Sc as o,nQt as p,xJt as q,cs as r,IKt as s,KKt as t,gen as u};
